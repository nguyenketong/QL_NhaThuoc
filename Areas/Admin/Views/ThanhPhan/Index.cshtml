@model IEnumerable<QL_NhaThuoc.Models.ThanhPhan>
@{
    ViewData["Title"] = "Quản lý thành phần";
}

<div class="d-flex justify-content-end mb-4">
    <a asp-action="Create" class="btn btn-success"><i class="fas fa-plus"></i> Thêm thành phần</a>
</div>

<div class="admin-table">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tên thành phần</th>
                <th>Mô tả</th>
                <th width="150">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MaThanhPhan</td>
                        <td><strong>@item.TenThanhPhan</strong></td>
                        <td>@item.MoTa</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.MaThanhPhan" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.MaThanhPhan" method="post" class="d-inline"
                                  onsubmit="return confirm('Xóa thành phần này?')">
                                <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">Chưa có thành phần nào</td>
                </tr>
            }
        </tbody>
    </table>
</div>
