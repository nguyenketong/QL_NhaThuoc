@model IEnumerable<QL_NhaThuoc.Models.BaiViet>
@{
    ViewData["Title"] = "Quản lý bài viết";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="fas fa-newspaper text-primary"></i> Quản lý bài viết</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Thêm bài viết
    </a>
</div>

@if (TempData["ThongBao"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle"></i> @TempData["ThongBao"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th width="80">Hình</th>
                    <th>Tiêu đề</th>
                    <th width="120">Ngày đăng</th>
                    <th width="80" class="text-center">Lượt xem</th>
                    <th width="80" class="text-center">Nổi bật</th>
                    <th width="80" class="text-center">Trạng thái</th>
                    <th width="120" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="@(string.IsNullOrEmpty(item.HinhAnh) ? "/images/no-image.svg" : item.HinhAnh)" 
                                     class="rounded" style="width: 60px; height: 45px; object-fit: cover;" 
                                     onerror="this.src='/images/no-image.svg'">
                            </td>
                            <td>
                                <strong>@item.TieuDe</strong>
                                @if (!string.IsNullOrEmpty(item.MoTaNgan))
                                {
                                    <br><small class="text-muted">@(item.MoTaNgan.Length > 80 ? item.MoTaNgan.Substring(0, 80) + "..." : item.MoTaNgan)</small>
                                }
                            </td>
                            <td>
                                <small>@(item.NgayDang?.ToString("dd/MM/yyyy") ?? "-")</small>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-info">@(item.LuotXem ?? 0)</span>
                            </td>
                            <td class="text-center">
                                <form asp-action="ToggleNoiBat" asp-route-id="@item.MaBaiViet" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm @(item.IsNoiBat == true ? "btn-warning" : "btn-outline-secondary")">
                                        <i class="fas fa-star"></i>
                                    </button>
                                </form>
                            </td>
                            <td class="text-center">
                                <form asp-action="ToggleActive" asp-route-id="@item.MaBaiViet" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-sm @(item.IsActive == true ? "btn-success" : "btn-outline-danger")">
                                        @(item.IsActive == true ? "Hiện" : "Ẩn")
                                    </button>
                                </form>
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.MaBaiViet" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.MaBaiViet" method="post" style="display:inline;"
                                      onsubmit="return confirm('Bạn có chắc muốn xóa bài viết này?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            <i class="fas fa-inbox fa-2x mb-2"></i><br>
                            Chưa có bài viết nào
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
