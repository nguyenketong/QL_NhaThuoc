@model QL_NhaThuoc.Models.BaiViet
@{
    ViewData["Title"] = "Sửa bài viết";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="fas fa-edit text-primary"></i> Sửa bài viết</h4>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại
    </a>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="MaBaiViet" />
    <input type="hidden" asp-for="NgayDang" />
    <input type="hidden" asp-for="LuotXem" />
    
    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <i class="fas fa-edit"></i> Nội dung bài viết
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Tiêu đề <span class="text-danger">*</span></label>
                        <input asp-for="TieuDe" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mô tả ngắn</label>
                        <textarea asp-for="MoTaNgan" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nội dung chi tiết</label>
                        <textarea asp-for="NoiDung" class="form-control" rows="10"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <i class="fas fa-image"></i> Hình ảnh
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.HinhAnh))
                    {
                        <div class="text-center mb-3">
                            <img src="@Model.HinhAnh" class="img-fluid rounded" style="max-height: 150px;" 
                                 onerror="this.src='/images/no-image.svg'">
                            <p class="small text-muted mt-2">Hình ảnh hiện tại</p>
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Thay đổi hình ảnh</label>
                        <input type="file" name="hinhAnhFile" class="form-control" accept="image/*" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hoặc nhập URL</label>
                        <input asp-for="HinhAnh" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <i class="fas fa-cog"></i> Tùy chọn
                </div>
                <div class="card-body">
                    <div class="form-check mb-3">
                        <input type="checkbox" name="IsNoiBat" value="true" class="form-check-input" id="chkNoiBat" @(Model.IsNoiBat == true ? "checked" : "") />
                        <label class="form-check-label" for="chkNoiBat">
                            <i class="fas fa-star text-warning"></i> Bài viết nổi bật
                        </label>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" name="IsActive" value="true" class="form-check-input" id="chkActive" @(Model.IsActive == true ? "checked" : "") />
                        <label class="form-check-label" for="chkActive">
                            <i class="fas fa-eye text-success"></i> Hiển thị bài viết
                        </label>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <small class="text-muted">
                        <i class="fas fa-calendar"></i> Ngày đăng: @(Model.NgayDang?.ToString("dd/MM/yyyy HH:mm") ?? "-")<br>
                        <i class="fas fa-eye"></i> Lượt xem: @(Model.LuotXem ?? 0)
                    </small>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fas fa-save"></i> Cập nhật
                </button>
            </div>
        </div>
    </div>
</form>
