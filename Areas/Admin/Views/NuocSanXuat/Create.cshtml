@model NuocSanXuat
@{
    ViewData["Title"] = "Thêm nước sản xuất";
}

<div class="row">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label class="form-label">Tên nước sản xuất <span class="text-danger">*</span></label>
                        <input asp-for="TenNuocSX" class="form-control" />
                        <span asp-validation-for="TenNuocSX" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Lưu</button>
                    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
