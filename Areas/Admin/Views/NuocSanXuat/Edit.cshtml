@model NuocSanXuat
@{
    ViewData["Title"] = "Sửa nước sản xuất";
}

<div class="row">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="MaNuocSX" />
                    <div class="mb-3">
                        <label class="form-label">Tên nước sản xuất <span class="text-danger">*</span></label>
                        <input asp-for="TenNuocSX" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Cập nhật</button>
                    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
                </form>
            </div>
        </div>
    </div>
</div>
