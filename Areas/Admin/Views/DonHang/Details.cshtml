@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    var donHang = Model as dynamic;
    var chiTietList = ViewBag.ChiTietDonHangs as IEnumerable<dynamic>;
}

<div class="row g-4">
    <div class="col-lg-8">
        <!-- Thông tin đơn hàng -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white"><h6 class="mb-0">Thông tin đơn hàng</h6></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Mã đơn:</strong> #@donHang.MaDonHang</p>
                        <p><strong>Ngày đặt:</strong> @((DateTime)donHang.NgayDatHang).ToString("dd/MM/yyyy HH:mm")</p>
                        <p><strong>Thanh toán:</strong> @donHang.PhuongThucThanhToan</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Khách hàng:</strong> @(donHang.HoTen ?? "N/A")</p>
                        <p><strong>SĐT:</strong> @donHang.SoDienThoai</p>
                        <p><strong>Địa chỉ:</strong> @donHang.DiaChiGiaoHang</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chi tiết sản phẩm -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><h6 class="mb-0">Sản phẩm</h6></div>
            <table class="table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-center">SL</th>
                        <th class="text-end">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @if (chiTietList != null)
                    {
                        @foreach (var ct in chiTietList)
                        {
                            <tr>
                                <td>@ct.TenThuoc</td>
                                <td class="text-end">@(((decimal?)ct.DonGia)?.ToString("N0"))đ</td>
                                <td class="text-center">@ct.SoLuong</td>
                                <td class="text-end fw-bold">@(((decimal?)ct.ThanhTien)?.ToString("N0"))đ</td>
                            </tr>
                        }
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <td colspan="3" class="text-end"><strong>Tổng cộng:</strong></td>
                        <td class="text-end text-danger fw-bold fs-5">@(((decimal?)donHang.TongTien)?.ToString("N0"))đ</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Cập nhật trạng thái -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><h6 class="mb-0">Trạng thái đơn hàng</h6></div>
            <div class="card-body">
                <div class="mb-3">
                    <strong>Hiện tại:</strong>
                    @{
                        var trangThai = (string)donHang.TrangThai;
                    }
                    @switch (trangThai)
                    {
                        case "Cho xu ly": <span class="badge bg-warning fs-6">Chờ xử lý</span> break;
                        case "Dang giao": <span class="badge bg-info fs-6">Đang giao</span> break;
                        case "Hoan thanh": <span class="badge bg-success fs-6">Hoàn thành</span> break;
                        default: <span class="badge bg-danger fs-6">Đã hủy</span> break;
                    }
                </div>
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="id" value="@donHang.MaDonHang" />
                    <select name="trangThai" class="form-select mb-3">
                        <option value="Cho xu ly">Chờ xử lý</option>
                        <option value="Dang giao">Đang giao</option>
                        <option value="Hoan thanh">Hoàn thành</option>
                        <option value="Da huy">Đã hủy</option>
                    </select>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-save"></i> Cập nhật
                    </button>
                </form>
            </div>
        </div>
        <a asp-action="Index" class="btn btn-secondary w-100 mt-3">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>
</div>
