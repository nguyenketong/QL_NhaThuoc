@model QL_NhaThuoc.Models.NguoiDung
@{
    ViewData["Title"] = "Chi tiết khách hàng";
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <div class="mb-3">
                    <i class="fas fa-user-circle" style="font-size: 5rem; color: #1E88E5;"></i>
                </div>
                <h5>@(Model.HoTen ?? Model.SoDienThoai)</h5>
                <p class="text-muted">@Model.SoDienThoai</p>
                <hr>
                <p><i class="fas fa-map-marker-alt text-primary"></i> @(Model.DiaChi ?? "Chưa cập nhật")</p>
                <p><i class="fas fa-calendar text-primary"></i> Tham gia: @Model.NgayTao?.ToString("dd/MM/yyyy")</p>
                <p><i class="fas fa-user-tag text-primary"></i> Vai trò: <span class="badge bg-info">@(Model.VaiTro ?? "KhachHang")</span></p>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white"><h6 class="mb-0">Lịch sử đơn hàng</h6></div>
            <table class="table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã ĐH</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.DonHangs != null && Model.DonHangs.Any())
                    {
                        @foreach (var dh in Model.DonHangs.OrderByDescending(d => d.NgayDatHang))
                        {
                            <tr>
                                <td><a asp-action="Details" asp-controller="DonHang" asp-route-id="@dh.MaDonHang">#@dh.MaDonHang</a></td>
                                <td>@dh.NgayDatHang.ToString("dd/MM/yyyy")</td>
                                <td class="text-danger">@(dh.TongTien?.ToString("N0") ?? "0")đ</td>
                                <td>
                                    @switch (dh.TrangThai)
                                    {
                                        case "Hoan thanh": <span class="badge bg-success">Hoàn thành</span> break;
                                        case "Cho xu ly": <span class="badge bg-warning">Chờ xử lý</span> break;
                                        case "Dang giao": <span class="badge bg-info">Đang giao</span> break;
                                        default: <span class="badge bg-secondary">@dh.TrangThai</span> break;
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-3">Chưa có đơn hàng nào</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3"><i class="fas fa-arrow-left"></i> Quay lại</a>
