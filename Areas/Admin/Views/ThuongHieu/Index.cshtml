@{
    ViewData["Title"] = "Quản lý thương hiệu";
}

<div class="d-flex justify-content-end mb-4">
    <a asp-action="Create" class="btn btn-success"><i class="fas fa-plus"></i> Thêm thương hiệu</a>
</div>

<div class="admin-table">
    <table class="table table-hover">
        <thead>
            <tr>
                <th width="60">ID</th>
                <th width="80">Logo</th>
                <th>Tên thương hiệu</th>
                <th>Quốc gia</th>
                <th>Số thuốc</th>
                <th width="150">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                var items = Model as IEnumerable<dynamic>;
                @foreach (var item in items)
                {
                    <tr>
                        <td>@item.MaThuongHieu</td>
                        <td>
                            @if (!string.IsNullOrEmpty((string)item.HinhAnh))
                            {
                                <img src="@item.HinhAnh" alt="@item.TenThuongHieu" style="max-width: 60px; max-height: 40px; object-fit: contain;" onerror="this.src='/images/no-image.svg'">
                            }
                            else
                            {
                                <div class="text-center text-muted" style="width: 60px; height: 40px; display: flex; align-items: center; justify-content: center; background: #f8f9fa; border-radius: 4px;">
                                    <i class="fas fa-building"></i>
                                </div>
                            }
                        </td>
                        <td><strong>@item.TenThuongHieu</strong></td>
                        <td>@item.QuocGia</td>
                        <td><span class="badge bg-info">@item.SoLuongThuoc</span></td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.MaThuongHieu" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.MaThuongHieu" method="post" class="d-inline"
                                  onsubmit="return confirm('Xóa thương hiệu này?')">
                                <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
