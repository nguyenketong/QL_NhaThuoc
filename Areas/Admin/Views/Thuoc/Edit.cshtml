@model Thuoc
@{
    ViewData["Title"] = "Sửa thuốc";
    var thanhPhans = ViewBag.ThanhPhans as List<QL_NhaThuoc.Models.ThanhPhan>;
    var tacDungPhus = ViewBag.TacDungPhus as List<QL_NhaThuoc.Models.TacDungPhu>;
    var doiTuongs = ViewBag.DoiTuongs as List<QL_NhaThuoc.Models.DoiTuongSuDung>;
    var selectedDoiTuongs = ViewBag.SelectedDoiTuongs as List<int> ?? new List<int>();
}

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="MaThuoc" />
    <input type="hidden" asp-for="NgayTao" />
    <div class="row">
        <!-- Thông tin cơ bản -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <i class="fas fa-info-circle"></i> Thông tin cơ bản
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label">Tên thuốc <span class="text-danger">*</span></label>
                            <input asp-for="TenThuoc" class="form-control" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Đơn vị tính</label>
                            <input asp-for="DonViTinh" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Nhóm thuốc <span class="text-danger">*</span></label>
                            <select asp-for="MaNhomThuoc" asp-items="ViewBag.NhomThuocs" class="form-select" required></select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Thương hiệu</label>
                            <select asp-for="MaThuongHieu" asp-items="ViewBag.ThuongHieus" class="form-select">
                                <option value="">-- Chọn --</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Nước sản xuất</label>
                            <select asp-for="MaNuocSX" asp-items="ViewBag.NuocSXs" class="form-select">
                                <option value="">-- Chọn --</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Mô tả</label>
                            <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Hình ảnh</label>
                            <input type="file" name="hinhAnhFile" class="form-control" accept="image/*" />
                            <small class="text-muted">Hoặc nhập URL:</small>
                            <input asp-for="HinhAnh" class="form-control mt-1" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Giá & Kho -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <i class="fas fa-dollar-sign"></i> Giá & Tồn kho
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Giá bán <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="GiaBan" type="number" class="form-control" required />
                                <span class="input-group-text">đ</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Số lượng tồn</label>
                            <input asp-for="SoLuongTon" type="number" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Số lượng đã bán</label>
                            <input asp-for="SoLuongDaBan" type="number" class="form-control" readonly />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Khuyến mãi -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-danger text-white">
                    <i class="fas fa-tags"></i> Khuyến mãi
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Giá gốc (trước KM)</label>
                            <div class="input-group">
                                <input asp-for="GiaGoc" type="number" class="form-control" />
                                <span class="input-group-text">đ</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Phần trăm giảm</label>
                            <div class="input-group">
                                <input asp-for="PhanTramGiam" type="number" class="form-control" min="0" max="100" />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Ngày bắt đầu KM</label>
                            <input asp-for="NgayBatDauKM" type="date" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Ngày kết thúc KM</label>
                            <input asp-for="NgayKetThucKM" type="date" class="form-control" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Đánh dấu sản phẩm</label>
                            <div class="d-flex gap-4 mt-2">
                                <div class="form-check">
                                    <input type="checkbox" name="IsHot" value="true" class="form-check-input" id="chkIsHot" 
                                           @(Model.IsHot == true ? "checked" : "") />
                                    <label class="form-check-label text-danger fw-bold" for="chkIsHot">🔥 HOT</label>
                                </div>
                                <div class="form-check">
                                    <input type="checkbox" name="IsNew" value="true" class="form-check-input" id="chkIsNew" 
                                           @(Model.IsNew == true ? "checked" : "") />
                                    <label class="form-check-label text-success fw-bold" for="chkIsNew">🆕 MỚI</label>
                                </div>
                                <div class="form-check">
                                    <input type="checkbox" name="IsActive" value="true" class="form-check-input" id="chkIsActive" 
                                           @(Model.IsActive != false ? "checked" : "") />
                                    <label class="form-check-label text-primary fw-bold" for="chkIsActive">✅ Kinh doanh</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Thành phần -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <i class="fas fa-flask"></i> Thành phần
                </div>
                <div class="card-body" id="thanhPhanContainer">
                    @if (Model.CT_ThanhPhans != null && Model.CT_ThanhPhans.Any())
                    {
                        @foreach (var ct in Model.CT_ThanhPhans)
                        {
                            <div class="thanh-phan-row mb-2">
                                <div class="row g-2">
                                    <div class="col-7">
                                        <select name="ThanhPhanIds" class="form-select form-select-sm">
                                            <option value="">-- Chọn --</option>
                                            @if (thanhPhans != null)
                                            {
                                                @foreach (var tp in thanhPhans)
                                                {
                                                    <option value="@tp.MaThanhPhan" selected="@(tp.MaThanhPhan == ct.MaThanhPhan)">@tp.TenThanhPhan</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-5">
                                        <input type="text" name="HamLuongs" class="form-control form-control-sm" placeholder="Hàm lượng" value="@ct.HamLuong" />
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="thanh-phan-row mb-2">
                            <div class="row g-2">
                                <div class="col-7">
                                    <select name="ThanhPhanIds" class="form-select form-select-sm">
                                        <option value="">-- Chọn --</option>
                                        @if (thanhPhans != null)
                                        {
                                            @foreach (var tp in thanhPhans)
                                            {
                                                <option value="@tp.MaThanhPhan">@tp.TenThanhPhan</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-5">
                                    <input type="text" name="HamLuongs" class="form-control form-control-sm" placeholder="Hàm lượng" />
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <button type="button" class="btn btn-sm btn-outline-success" onclick="themThanhPhan()">
                        <i class="fas fa-plus"></i> Thêm thành phần
                    </button>
                </div>
            </div>

            <!-- Tác dụng phụ -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-warning text-dark">
                    <i class="fas fa-exclamation-triangle"></i> Tác dụng phụ
                </div>
                <div class="card-body" id="tacDungPhuContainer">
                    @if (Model.CT_TacDungPhus != null && Model.CT_TacDungPhus.Any())
                    {
                        @foreach (var ct in Model.CT_TacDungPhus)
                        {
                            <div class="tac-dung-phu-row mb-2">
                                <div class="row g-2">
                                    <div class="col-7">
                                        <select name="TacDungPhuIds" class="form-select form-select-sm">
                                            <option value="">-- Chọn --</option>
                                            @if (tacDungPhus != null)
                                            {
                                                @foreach (var tdp in tacDungPhus)
                                                {
                                                    <option value="@tdp.MaTacDungPhu" selected="@(tdp.MaTacDungPhu == ct.MaTacDungPhu)">@tdp.TenTacDungPhu</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-5">
                                        <select name="MucDos" class="form-select form-select-sm">
                                            <option value="">Mức độ</option>
                                            <option value="Nhẹ" selected="@(ct.MucDo == "Nhẹ")">Nhẹ</option>
                                            <option value="Trung bình" selected="@(ct.MucDo == "Trung bình")">Trung bình</option>
                                            <option value="Nặng" selected="@(ct.MucDo == "Nặng")">Nặng</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="tac-dung-phu-row mb-2">
                            <div class="row g-2">
                                <div class="col-7">
                                    <select name="TacDungPhuIds" class="form-select form-select-sm">
                                        <option value="">-- Chọn --</option>
                                        @if (tacDungPhus != null)
                                        {
                                            @foreach (var tdp in tacDungPhus)
                                            {
                                                <option value="@tdp.MaTacDungPhu">@tdp.TenTacDungPhu</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-5">
                                    <select name="MucDos" class="form-select form-select-sm">
                                        <option value="">Mức độ</option>
                                        <option value="Nhẹ">Nhẹ</option>
                                        <option value="Trung bình">Trung bình</option>
                                        <option value="Nặng">Nặng</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <button type="button" class="btn btn-sm btn-outline-warning" onclick="themTacDungPhu()">
                        <i class="fas fa-plus"></i> Thêm tác dụng phụ
                    </button>
                </div>
            </div>

            <!-- Đối tượng sử dụng -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-info text-white">
                    <i class="fas fa-users"></i> Đối tượng sử dụng
                </div>
                <div class="card-body">
                    @if (doiTuongs != null)
                    {
                        @foreach (var dt in doiTuongs)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="DoiTuongIds" value="@dt.MaDoiTuong" 
                                       id="dt_@dt.MaDoiTuong" @(selectedDoiTuongs.Contains(dt.MaDoiTuong) ? "checked" : "")>
                                <label class="form-check-label" for="dt_@dt.MaDoiTuong">@dt.TenDoiTuong</label>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary btn-lg">
            <i class="fas fa-save"></i> Cập nhật
        </button>
        <a asp-action="Index" class="btn btn-secondary btn-lg">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>
</form>

@section Scripts {
<script>
    // Lấy các input
    const giaBanInput = document.getElementById('GiaBan');
    const giaGocInput = document.getElementById('GiaGoc');
    const phanTramGiamInput = document.getElementById('PhanTramGiam');

    // Khi thay đổi Giá gốc → tính Giá bán (nếu có phần trăm giảm)
    giaGocInput.addEventListener('input', function() {
        const giaGoc = parseFloat(this.value) || 0;
        const phanTram = parseFloat(phanTramGiamInput.value) || 0;
        if (giaGoc > 0 && phanTram > 0) {
            const giaBan = Math.round(giaGoc * (100 - phanTram) / 100);
            giaBanInput.value = giaBan;
        }
    });

    // Khi thay đổi Phần trăm giảm → tính Giá bán (nếu có giá gốc)
    phanTramGiamInput.addEventListener('input', function() {
        const phanTram = parseFloat(this.value) || 0;
        const giaGoc = parseFloat(giaGocInput.value) || 0;
        if (giaGoc > 0 && phanTram > 0 && phanTram < 100) {
            const giaBan = Math.round(giaGoc * (100 - phanTram) / 100);
            giaBanInput.value = giaBan;
        }
    });

    // Khi thay đổi Giá bán → tính Phần trăm giảm (nếu có giá gốc)
    giaBanInput.addEventListener('input', function() {
        const giaBan = parseFloat(this.value) || 0;
        const giaGoc = parseFloat(giaGocInput.value) || 0;
        if (giaGoc > 0 && giaBan > 0 && giaGoc > giaBan) {
            const phanTram = Math.round((giaGoc - giaBan) * 100 / giaGoc);
            phanTramGiamInput.value = phanTram;
        }
    });

    function themThanhPhan() {
        var container = document.getElementById('thanhPhanContainer');
        var firstRow = container.querySelector('.thanh-phan-row');
        var newRow = firstRow.cloneNode(true);
        newRow.querySelectorAll('select, input').forEach(el => el.value = '');
        container.appendChild(newRow);
    }

    function themTacDungPhu() {
        var container = document.getElementById('tacDungPhuContainer');
        var firstRow = container.querySelector('.tac-dung-phu-row');
        var newRow = firstRow.cloneNode(true);
        newRow.querySelectorAll('select').forEach(el => el.value = '');
        container.appendChild(newRow);
    }
</script>
}
