@model IEnumerable<QL_NhaThuoc.Models.Thuoc>
@{
    ViewData["Title"] = "Quản lý thuốc";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" class="form-control" placeholder="Tìm kiếm..." value="@Context.Request.Query["search"]" />
            <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
        </form>
    </div>
    <a asp-action="Create" class="btn btn-success">
        <i class="fas fa-plus"></i> Thêm thuốc
    </a>
</div>

<div class="admin-table">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tên thuốc</th>
                <th>Nhóm</th>
                <th>Thương hiệu</th>
                <th>Giá bán</th>
                <th>Đơn vị</th>
                <th width="150">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MaThuoc</td>
                        <td><strong>@item.TenThuoc</strong></td>
                        <td><span class="badge bg-info">@item.NhomThuoc?.TenNhomThuoc</span></td>
                        <td>@item.ThuongHieu?.TenThuongHieu</td>
                        <td class="text-danger fw-bold">@item.GiaBan?.ToString("N0")đ</td>
                        <td>@item.DonViTinh</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.MaThuoc" class="btn btn-sm btn-warning">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.MaThuoc" method="post" class="d-inline"
                                  onsubmit="return confirm('Bạn có chắc muốn xóa?')">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">
                        <i class="fas fa-info-circle"></i> Chưa có thuốc nào
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
