@model IEnumerable<QL_NhaThuoc.Models.Thuoc>
@{
    ViewData["Title"] = "Nhà Thuốc Tây - Chăm sóc sức khỏe toàn diện";
    var sanPhamMoi = ViewBag.SanPhamMoi as List<QL_NhaThuoc.Models.Thuoc>;
    var sanPhamHot = ViewBag.SanPhamHot as List<QL_NhaThuoc.Models.Thuoc>;
    var sanPhamBanChay = ViewBag.SanPhamBanChay as List<QL_NhaThuoc.Models.Thuoc>;
    var nhomThuocs = ViewBag.NhomThuocs as List<QL_NhaThuoc.Models.NhomThuoc>;
    var thuongHieus = ViewBag.ThuongHieus as List<QL_NhaThuoc.Models.ThuongHieu>;
    var baiViets = ViewBag.BaiViets as List<QL_NhaThuoc.Models.BaiViet>;
    var baiVietNoiBat = baiViets?.FirstOrDefault(b => b.IsNoiBat == true) ?? baiViets?.FirstOrDefault();
    var baiVietKhac = baiViets?.Where(b => b.MaBaiViet != baiVietNoiBat?.MaBaiViet).ToList();
}

