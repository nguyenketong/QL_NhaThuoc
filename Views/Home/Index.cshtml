                    <div class="quick-cat-icon">
                        <i class="fas fa-pills"></i>
                    </div>
                    <span>Giảm đau<br>Hạ sốt</span>
                </a>
            </div>
            <div class="col-4 col-md-2">
                <a asp-controller="Thuoc" asp-action="TheoNhom" asp-route-id="5" class="quick-cat-item d-block text-decoration-none">
                    <div class="quick-cat-icon">
                        <i class="fas fa-capsules"></i>
                    </div>
                    <span>Vitamin<br>TPCN</span>
                </a>
            </div>
            <div class="col-4 col-md-2">
                <a asp-controller="Thuoc" asp-action="TheoNhom" asp-route-id="4" class="quick-cat-item d-block text-decoration-none">
                    <div class="quick-cat-icon">
                        <i class="fas fa-head-side-virus"></i>
                    </div>
                    <span>Cảm cúm<br>Sốt</span>
                </a>
            </div>
            <div class="col-4 col-md-2">
                <a asp-controller="Thuoc" asp-action="TheoNhom" asp-route-id="2" class="quick-cat-item d-block text-decoration-none">
                    <div class="quick-cat-icon">
                        <i class="fas fa-bacteria"></i>
                    </div>
                    <span>Kháng sinh<br>Kháng viêm</span>
                </a>
            </div>
            <div class="col-4 col-md-2">
                <a asp-controller="Thuoc" asp-action="TheoNhom" asp-route-id="3" class="quick-cat-item d-block text-decoration-none">
                    <div class="quick-cat-icon">
                        <i class="fas fa-stomach"></i>
                    </div>
                    <span>Tiêu hóa<br>Dạ dày</span>
                </a>
            </div>
            <div class="col-4 col-md-2">
                <a asp-controller="NhomThuoc" asp-action="DanhSach" class="quick-cat-item d-block text-decoration-none">
