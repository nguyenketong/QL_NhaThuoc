<!-- SẢN PHẨM BÁN CHẠY -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="section-header text-center mb-4">
            <h2 class="section-title-main text-primary fw-bold">SẢN PHẨM BÁN CHẠY</h2>
            <p class="text-muted">Một số dòng sản phẩm bán chạy của công ty chúng tôi đang kinh doanh hiện tại</p>
            <div class="title-divider"></div>
        </div>
        
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-3">
            @if (sanPhamBanChay != null && sanPhamBanChay.Any())
            {
                @foreach (var thuoc in sanPhamBanChay.Take(10))
                {
                    <div class="col">
                        <div class="product-card-compact">
                            <div class="product-badge-hot">Hot</div>
                            <div class="product-img-compact">
                                <a asp-controller="Thuoc" asp-action="ChiTiet" asp-route-id="@thuoc.MaThuoc">
                                    <img src="@(string.IsNullOrEmpty(thuoc.HinhAnh) ? "/images/no-image.svg" : thuoc.HinhAnh)" 
                                         alt="@thuoc.TenThuoc" onerror="this.src='/images/no-image.svg'">
                                </a>
                            </div>
                            <div class="product-content-compact">
                                <a asp-controller="Thuoc" asp-action="ChiTiet" asp-route-id="@thuoc.MaThuoc" class="product-title-compact">
                                    @thuoc.TenThuoc
                                </a>
                                <div class="product-price-compact">@((thuoc.GiaBan ?? 0).ToString("N0"))đ</div>
                                <div class="product-actions-compact">
                                    <a asp-controller="Thuoc" asp-action="ChiTiet" asp-route-id="@thuoc.MaThuoc" class="btn btn-outline-primary btn-sm">
                                        <i class="fas fa-eye me-1"></i>Chi tiết
                                    </a>
                                    <button onclick="themVaoGioHang(@thuoc.MaThuoc)" class="btn btn-primary btn-sm">
                                        <i class="fas fa-cart-plus me-1"></i>Thêm giỏ
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- SẢN PHẨM KHUYẾN MÃI -->
<section class="py-5 promo-section">
    <div class="container">
        <div class="section-header text-center mb-4">
            <h2 class="section-title-main text-primary fw-bold">SẢN PHẨM KHUYẾN MÃI</h2>
            <p class="text-muted">Một số dòng sản phẩm bán chạy của công ty chúng tôi đang kinh doanh hiện tại</p>
            <div class="title-divider"></div>
        </div>
        
        <!-- Category Tabs -->
        <div class="promo-tabs-wrapper text-center mb-4">
            <div class="promo-tabs d-inline-flex flex-wrap justify-content-center gap-2">
                <button class="promo-tab" data-category="detox">THIẾT BỊ Y TẾ</button>
                <button class="promo-tab" data-category="makeup">DƯỢC MỸ PHẨM</button>
                <button class="promo-tab" data-category="milk">MẸ VÀ BÉ</button>
                <button class="promo-tab" data-category="supplement">THỰC PHẨM CHỨC NĂNG</button>
                <button class="promo-tab" data-category="pharma">DƯỢC PHẨM</button>
            </div>
        </div>
        
        <!-- Products Grid -->
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-3">
            @if (sanPhamHot != null && sanPhamHot.Any())
            {
                @foreach (var thuoc in sanPhamHot.Take(10))
                {
                    var giaBan = thuoc.GiaBan ?? 0;
                    var phanTramGiam = (thuoc.PhanTramGiam.HasValue && thuoc.PhanTramGiam.Value > 0) 
                        ? thuoc.PhanTramGiam.Value : 0;
                    // Kiểm tra khuyến mãi còn hiệu lực
                    var dangKhuyenMai = phanTramGiam > 0 
                        && (!thuoc.NgayBatDauKM.HasValue || thuoc.NgayBatDauKM <= DateTime.Now)
                        && (!thuoc.NgayKetThucKM.HasValue || thuoc.NgayKetThucKM >= DateTime.Now);
                    // Tính giá gốc
                    var giaGoc = thuoc.GiaGoc ?? (phanTramGiam > 0 ? Math.Ceiling(giaBan * 100 / (100 - phanTramGiam)) : giaBan);
                    // Nếu hết khuyến mãi, hiển thị giá gốc
                    if (!dangKhuyenMai && phanTramGiam > 0)
                    {
                        giaBan = giaGoc;
                        phanTramGiam = 0;
                    }
                    var isHot = thuoc.IsHot ?? false;
                    var hetHang = (thuoc.SoLuongTon ?? 0) <= 0;
                    <div class="col">
                        <div class="product-card-promo @(hetHang ? "out-of-stock" : "")">
                            <div class="promo-badges">
                                @if (hetHang)
                                {
                                    <span class="badge-soldout">Hết hàng</span>
                                }
                                else if (isHot)
                                {
                                    <span class="badge-hot">Nóng</span>
                                }
                                @if (dangKhuyenMai && phanTramGiam > 0)
                                {
                                    <span class="badge-discount">-@phanTramGiam%</span>
                                }
                            </div>
                            <div class="product-img-promo">
                                <a asp-controller="Thuoc" asp-action="ChiTiet" asp-route-id="@thuoc.MaThuoc">
                                    <img src="@(string.IsNullOrEmpty(thuoc.HinhAnh) ? "/images/no-image.svg" : thuoc.HinhAnh)" 
                                         alt="@thuoc.TenThuoc" onerror="this.src='/images/no-image.svg'">
                                </a>
                            </div>
                            <div class="product-content-promo">
                                <a asp-controller="Thuoc" asp-action="ChiTiet" asp-route-id="@thuoc.MaThuoc" class="product-title-promo">
                                    @thuoc.TenThuoc
                                </a>
                                <div class="product-price-promo">
                                    <span class="price-current">@giaBan.ToString("N0")đ</span>
                                    @if (dangKhuyenMai && phanTramGiam > 0)
                                    {
                                        <span class="price-original">@giaGoc.ToString("N0")đ</span>
                                    }
                                </div>
                                @if (dangKhuyenMai && thuoc.NgayKetThucKM.HasValue)
                                {
                                    <div class="promo-countdown text-warning small mb-1">
                                        <i class="fas fa-clock"></i> Đến @thuoc.NgayKetThucKM.Value.ToString("dd/MM")
                                    </div>
                                }
                                @if (hetHang)
                                {
                                    <button class="btn-buy-now disabled" disabled>Hết hàng</button>
                                }
                                else
                                {
                                    <button onclick="themVaoGioHang(@thuoc.MaThuoc)" class="btn-buy-now">Mua ngay</button>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-4">
                    <p class="text-muted">Chưa có sản phẩm khuyến mãi</p>
                </div>
            }
        </div>
    </div>
</section>

