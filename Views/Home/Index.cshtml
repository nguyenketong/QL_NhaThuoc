</section>

<!-- Flash Sale Section -->
<section class="container mt-4">
    <div class="flash-sale-section px-4">
        <div class="flash-sale-header">
            <div class="flash-sale-title">
                <i class="fas fa-bolt"></i> FLASH SALE - GIÁ TỐT
            </div>
            <div class="countdown">
                <div class="countdown-item" id="hours">00</div>
                <div class="countdown-item">:</div>
                <div class="countdown-item" id="minutes">00</div>
                <div class="countdown-item">:</div>
                <div class="countdown-item" id="seconds">00</div>
            </div>
        </div>
        <div class="row g-3">
            @if (Model != null)
            {
                var items = Model as IEnumerable<dynamic>;
                @foreach (var thuoc in items.Take(4))
                {
                    <div class="col-6 col-md-3">
                        <div class="product-card bg-white">
                            <div class="product-badge">
                                <span class="badge badge-sale">-15%</span>
                            </div>
                            <div class="product-image">
                                <img src="@(string.IsNullOrEmpty((string)thuoc.HinhAnh) ? "/images/no-image.svg" : thuoc.HinhAnh)" 
                                     alt="@thuoc.TenThuoc" onerror="this.src='/images/no-image.svg'" />
                            </div>
                            <div class="product-info">
                                <div class="product-category">@thuoc.TenNhomThuoc</div>
                                <h6 class="product-name">@thuoc.TenThuoc</h6>
                                <div class="product-price">
                                    <span class="price-current">@(((decimal?)thuoc.GiaBan ?? 0).ToString("N0"))đ</span>
                                    <span class="price-unit">/Hộp</span>
                                </div>
                            </div>
                            <div class="product-footer">
                                <a asp-controller="Thuoc" asp-action="ChiTiet" asp-route-id="@thuoc.MaThuoc" 
                                   class="btn btn-outline-primary btn-sm">Chi tiết</a>
                                <button onclick="themVaoGioHang(@thuoc.MaThuoc)" class="btn btn-cart btn-sm">
                                    <i class="fas fa-cart-plus"></i> Mua
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- Sản phẩm nổi bật -->
<section class="container py-5">
    <h3 class="section-title">
        <i class="fas fa-star"></i> Sản phẩm bán chạy
    </h3>
    <div class="row g-4">
        @if (Model != null)
        {
            var allItems = Model as IEnumerable<dynamic>;
            @foreach (var thuoc in allItems)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="product-card">
                        <div class="product-badge">
                            <span class="badge badge-hot">HOT</span>
                        </div>
                        <div class="product-image">
                            <img src="@(string.IsNullOrEmpty((string)thuoc.HinhAnh) ? "/images/no-image.svg" : thuoc.HinhAnh)" 
                                 alt="@thuoc.TenThuoc" onerror="this.src='/images/no-image.svg'" />
                            <div class="product-actions">
                                <button class="btn" title="Xem nhanh" onclick="xemNhanh(@thuoc.MaThuoc)">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="btn" title="Yêu thích">
                                    <i class="fas fa-heart"></i>
                                </button>
                            </div>
                        </div>
                        <div class="product-info">
                            <div class="product-category">@thuoc.TenNhomThuoc</div>
                            <a asp-controller="Thuoc" asp-action="ChiTiet" asp-route-id="@thuoc.MaThuoc" class="text-decoration-none">
                                <h6 class="product-name">@thuoc.TenThuoc</h6>
                            </a>
                            <div class="product-brand">
                                <i class="fas fa-building"></i> @(thuoc.TenThuongHieu ?? "Đang cập nhật")
                            </div>
                            <div class="product-price">
                                <span class="price-current">@(((decimal?)thuoc.GiaBan ?? 0).ToString("N0"))đ</span>
                                <span class="price-unit">/Hộp</span>
                            </div>
                        </div>
                        <div class="product-footer">
                            <a asp-controller="Thuoc" asp-action="ChiTiet" asp-route-id="@thuoc.MaThuoc" 
                               class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-info-circle"></i> Chi tiết
                            </a>
                            <button onclick="themVaoGioHang(@thuoc.MaThuoc)" class="btn btn-primary btn-sm">
                                <i class="fas fa-cart-plus"></i> Thêm
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle"></i> Chưa có sản phẩm nào. Vui lòng thêm dữ liệu vào database.
                </div>
            </div>
        }
    </div>
    <div class="text-center mt-4">
        <a asp-controller="Thuoc" asp-action="DanhSach" class="btn btn-outline-primary btn-lg">
            <i class="fas fa-th-large"></i> Xem tất cả sản phẩm
        </a>
    </div>
</section>

