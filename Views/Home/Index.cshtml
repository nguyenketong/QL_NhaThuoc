@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero Banner -->
<section class="hero-banner">
    <div class="container">
        <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
            </div>
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <div class="banner-content">
                        <h2>Chăm sóc sức khỏe toàn diện</h2>
                        <p>Thuốc chính hãng - Giá tốt nhất</p>
                        <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg">Mua ngay</a>
                    </div>
                </div>
                <div class="carousel-item">
                    <div class="banner-content">
                        <h2>Miễn phí giao hàng</h2>
                        <p>Đơn hàng từ 300.000đ</p>
                        <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg">Khám phá</a>
                    </div>
                </div>
                <div class="carousel-item">
                    <div class="banner-content">
                        <h2>Tư vấn dược sĩ miễn phí</h2>
                        <p>Hotline: 1800 6928</p>
                        <a href="#" class="btn btn-primary btn-lg">Liên hệ ngay</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories -->
<section class="categories-section py-5">
    <div class="container">
        <h3 class="section-title">Danh mục nổi bật</h3>
        <div class="row g-4">
            <div class="col-md-3">
                <div class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-pills"></i>
                    </div>
                    <h5>Thuốc không kê đơn</h5>
                    <a asp-controller="Category" asp-action="Products" asp-route-id="1">Xem thêm <i class="fas fa-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-md-3">
                <div class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-capsules"></i>
                    </div>
                    <h5>Thực phẩm chức năng</h5>
                    <a asp-controller="Category" asp-action="Products" asp-route-id="2">Xem thêm <i class="fas fa-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-md-3">
                <div class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-heartbeat"></i>
                    </div>
                    <h5>Chăm sóc sức khỏe</h5>
                    <a asp-controller="Category" asp-action="Products" asp-route-id="3">Xem thêm <i class="fas fa-arrow-right"></i></a>
                </div>
            </div>
            <div class="col-md-3">
                <div class="category-card">
                    <div class="category-icon">
                        <i class="fas fa-baby"></i>
                    </div>
                    <h5>Mẹ và bé</h5>
                    <a asp-controller="Category" asp-action="Products" asp-route-id="4">Xem thêm <i class="fas fa-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Products -->
<section class="products-section py-5 bg-light">
    <div class="container">
        <h3 class="section-title">Sản phẩm nổi bật</h3>
        <div class="row g-4">
            @for (int i = 1; i <= 8; i++)
            {
                <div class="col-md-3">
                    <div class="product-card">
                        <div class="product-badge">-20%</div>
                        <div class="product-image">
                            <img src="https://via.placeholder.com/250x250?text=Thuoc+@i" alt="Product @i" />
                        </div>
                        <div class="product-info">
                            <h6 class="product-name">Thuốc giảm đau Paracetamol @i</h6>
                            <div class="product-price">
                                <span class="price-new">@((i * 15000).ToString("N0"))đ</span>
                                <span class="price-old">@((i * 20000).ToString("N0"))đ</span>
                            </div>
                            <div class="product-rating">
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star-half-alt"></i>
                                <span>(125)</span>
                            </div>
                            <button class="btn btn-primary btn-sm w-100 mt-2">
                                <i class="fas fa-cart-plus"></i> Thêm vào giỏ
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-4">
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary">Xem tất cả sản phẩm</a>
        </div>
    </div>
</section>

<!-- Why Choose Us -->
<section class="features-section py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-3">
                <div class="feature-box">
                    <i class="fas fa-shipping-fast"></i>
                    <h5>Giao hàng nhanh</h5>
                    <p>Miễn phí ship đơn từ 300k</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="feature-box">
                    <i class="fas fa-certificate"></i>
                    <h5>Chính hãng 100%</h5>
                    <p>Cam kết thuốc chính hãng</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="feature-box">
                    <i class="fas fa-user-md"></i>
                    <h5>Tư vấn dược sĩ</h5>
                    <p>Hỗ trợ 24/7</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="feature-box">
                    <i class="fas fa-undo"></i>
                    <h5>Đổi trả dễ dàng</h5>
                    <p>Trong vòng 30 ngày</p>
                </div>
            </div>
        </div>
    </div>
</section>
