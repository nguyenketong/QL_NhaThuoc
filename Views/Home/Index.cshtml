<script>
document.addEventListener('DOMContentLoaded', function() {
    var wrapper = document.querySelector('.health-list-wrapper');
    var scrollContainer = document.getElementById('healthListScroll');
    
    if (scrollContainer && wrapper) {
        // Duplicate content for infinite scroll
        var content = scrollContainer.innerHTML;
        scrollContainer.innerHTML = content + content;
        
        // Drag to scroll
        var isDown = false;
        var startY;
        var scrollTop;
        
        wrapper.style.overflow = 'hidden';
        wrapper.style.cursor = 'grab';
        
        wrapper.addEventListener('mousedown', function(e) {
            isDown = true;
            wrapper.style.cursor = 'grabbing';
            scrollContainer.style.animation = 'none';
            startY = e.pageY - wrapper.offsetTop;
            scrollTop = wrapper.scrollTop;
            e.preventDefault();
        });
        
        wrapper.addEventListener('mouseleave', function() {
            isDown = false;
            wrapper.style.cursor = 'grab';
        });
        
        wrapper.addEventListener('mouseup', function() {
            isDown = false;
            wrapper.style.cursor = 'grab';
            // Resume animation after 2 seconds
            setTimeout(function() {
                if (!isDown) {
                    scrollContainer.style.animation = 'scrollUp 15s linear infinite';
                }
            }, 2000);
        });
        
        wrapper.addEventListener('mousemove', function(e) {
            if (!isDown) return;
            e.preventDefault();
            var y = e.pageY - wrapper.offsetTop;
            var walk = (y - startY) * 2;
            wrapper.scrollTop = scrollTop - walk;
        });
        
        // Touch support for mobile
        wrapper.addEventListener('touchstart', function(e) {
            scrollContainer.style.animation = 'none';
            startY = e.touches[0].pageY - wrapper.offsetTop;
            scrollTop = wrapper.scrollTop;
        });
        
        wrapper.addEventListener('touchmove', function(e) {
            var y = e.touches[0].pageY - wrapper.offsetTop;
            var walk = (y - startY) * 2;
            wrapper.scrollTop = scrollTop - walk;
        });
        
        wrapper.addEventListener('touchend', function() {
            setTimeout(function() {
                scrollContainer.style.animation = 'scrollUp 15s linear infinite';
            }, 2000);
        });
    }
});

// Brand Slider - Drag to scroll
document.addEventListener('DOMContentLoaded', function() {
    var slider = document.getElementById('brandSlider');
    if (!slider) return;
    
    var isDown = false;
    var startX;
    var scrollLeft;
    
    slider.addEventListener('mousedown', function(e) {
        isDown = true;
        slider.classList.add('dragging');
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
        e.preventDefault();
    });
    
    slider.addEventListener('mouseleave', function() {
        isDown = false;
        slider.classList.remove('dragging');
    });
    
    slider.addEventListener('mouseup', function() {
        isDown = false;
        slider.classList.remove('dragging');
    });
    
    slider.addEventListener('mousemove', function(e) {
        if (!isDown) return;
        e.preventDefault();
        var x = e.pageX - slider.offsetLeft;
        var walk = (x - startX) * 2;
        slider.scrollLeft = scrollLeft - walk;
    });
    
    // Touch support
    slider.addEventListener('touchstart', function(e) {
        startX = e.touches[0].pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
    });
    
    slider.addEventListener('touchmove', function(e) {
        var x = e.touches[0].pageX - slider.offsetLeft;
        var walk = (x - startX) * 2;
        slider.scrollLeft = scrollLeft - walk;
    });
});

function scrollBrands(direction) {
    var slider = document.getElementById('brandSlider');
    if (slider) {
        var scrollAmount = 200;
        slider.scrollBy({ left: direction * scrollAmount, behavior: 'smooth' });
    }
}
</script>
