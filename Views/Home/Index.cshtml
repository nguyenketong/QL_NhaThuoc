<!-- GÓC SỨC KHỎE & CHỨNG CHỈ -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row g-4">
            <!-- Góc sức khỏe -->
            <div class="col-lg-6">
                <h4 class="text-primary fw-bold mb-3">GÓC SỨC KHỎE</h4>
                <p class="text-muted small mb-4">Chia sẻ kiến thức y tế, sức khỏe và chăm sóc bản thân</p>
                
                @if (baiViets != null && baiViets.Any())
                {
                    <div class="row g-3">
                        <!-- Bài viết lớn bên trái -->
                        <div class="col-5">
                            @if (baiVietNoiBat != null)
                            {
                                <div class="health-main-article">
                                    <a asp-controller="BaiViet" asp-action="ChiTiet" asp-route-id="@baiVietNoiBat.MaBaiViet">
                                        <div class="health-main-img">
                                            @if (!string.IsNullOrEmpty(baiVietNoiBat.HinhAnh))
                                            {
                                                <img src="@baiVietNoiBat.HinhAnh" alt="@baiVietNoiBat.TieuDe" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                                <div class="health-main-placeholder" style="display:none;">
                                                    <i class="fas fa-heartbeat fa-3x text-primary"></i>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="health-main-placeholder">
                                                    <i class="fas fa-heartbeat fa-3x text-primary"></i>
                                                </div>
                                            }
                                        </div>
                                    </a>
                                    <h6 class="mt-2">@baiVietNoiBat.TieuDe</h6>
                                    <p class="text-muted small">@(baiVietNoiBat.MoTaNgan?.Length > 80 ? baiVietNoiBat.MoTaNgan.Substring(0, 80) + "..." : baiVietNoiBat.MoTaNgan)</p>
                                    <a asp-controller="BaiViet" asp-action="GocSucKhoe" class="btn btn-primary btn-sm">Xem Thêm</a>
                                </div>
                            }
                        </div>
                        
                        <!-- Danh sách bài viết nhỏ bên phải - Auto scroll -->
                        <div class="col-7">
                            <div class="health-list-wrapper">
                                <div class="health-list-scroll" id="healthListScroll">
                                    @if (baiVietKhac != null)
                                    {
                                        @foreach (var bv in baiVietKhac)
                                        {
                                            <a asp-controller="BaiViet" asp-action="ChiTiet" asp-route-id="@bv.MaBaiViet" class="health-small-item">
                                                <div class="health-small-img">
                                                    @if (!string.IsNullOrEmpty(bv.HinhAnh))
                                                    {
                                                        <img src="@bv.HinhAnh" alt="@bv.TieuDe" onerror="this.src='/images/no-image.svg'">
                                                    }
                                                    else
                                                    {
                                                        <div class="health-small-placeholder">
                                                            <i class="fas fa-newspaper text-primary"></i>
                                                        </div>
                                                    }
                                                </div>
                                                <div class="health-small-content">
                                                    <h6>@(bv.TieuDe.Length > 35 ? bv.TieuDe.Substring(0, 35) + "..." : bv.TieuDe)</h6>
                                                    <div class="health-small-date">
                                                        <i class="far fa-calendar-alt text-primary"></i>
                                                        <span class="text-primary">@(bv.NgayDang?.ToString("dd/MM/yyyy") ?? "-")</span>
                                                    </div>
                                                    <p class="small text-muted mb-0">@(bv.MoTaNgan?.Length > 60 ? bv.MoTaNgan.Substring(0, 60) + "..." : bv.MoTaNgan)</p>
                                                </div>
                                            </a>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-4 bg-white rounded shadow-sm">
                        <i class="fas fa-newspaper fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Chưa có bài viết nào</p>
                        <a asp-controller="BaiViet" asp-action="GocSucKhoe" class="btn btn-outline-primary btn-sm">Xem tất cả</a>
