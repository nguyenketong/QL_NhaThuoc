@model QL_NhaThuoc.Models.DonHang
@{
    ViewData["Title"] = "Theo dõi đơn hàng";
}

<div class="container my-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="DanhSach">Đơn hàng</a></li>
            <li class="breadcrumb-item active">Theo dõi #@Model.MaDonHang</li>
        </ol>
    </nav>

    <h1 class="mb-4">Theo dõi đơn hàng #@Model.MaDonHang</h1>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <strong>Ngày đặt hàng:</strong><br>
                            @Model.NgayDatHang.ToString("dd/MM/yyyy HH:mm")
                        </div>
                        <div class="col-md-6">
                            <strong>Tổng tiền:</strong><br>
                            <span class="text-danger fs-5">@Model.TongTien?.ToString("N0") đ</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <strong>Địa chỉ giao hàng:</strong><br>
                        @Model.DiaChiGiaoHang
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Trạng thái đơn hàng</h5>
                </div>
                <div class="card-body">
                    <div class="timeline">
                        @{
                            var trangThai = Model.TrangThai ?? "";
                            var choXuLy = trangThai == "Cho xu ly" || trangThai == "Dang giao" || trangThai == "Hoan thanh";
                            var dangGiao = trangThai == "Dang giao" || trangThai == "Hoan thanh";
                            var hoanThanh = trangThai == "Hoan thanh";
                            var daHuy = trangThai == "Da huy";
                        }

                        <div class="step @(choXuLy ? "active" : "")">
                            <div class="step-icon">
                                <i class="bi bi-check-circle"></i>
                            </div>
                            <div class="step-content">
                                <h6>Đơn hàng đã đặt</h6>
                                <p class="text-muted small">@Model.NgayDatHang.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                        </div>

                        @if (!daHuy)
                        {
                            <div class="step @(dangGiao ? "active" : "")">
                                <div class="step-icon">
                                    <i class="bi bi-truck"></i>
                                </div>
                                <div class="step-content">
                                    <h6>Đang giao hàng</h6>
                                    <p class="text-muted small">@(dangGiao ? "Đơn hàng đang được vận chuyển" : "Chờ xử lý")</p>
                                </div>
                            </div>

                            <div class="step @(hoanThanh ? "active" : "")">
                                <div class="step-icon">
                                    <i class="bi bi-box-seam"></i>
                                </div>
                                <div class="step-content">
                                    <h6>Giao hàng thành công</h6>
                                    <p class="text-muted small">@(hoanThanh ? "Đơn hàng đã được giao" : "Chưa hoàn thành")</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="step active">
                                <div class="step-icon bg-danger">
                                    <i class="bi bi-x-circle"></i>
                                </div>
                                <div class="step-content">
                                    <h6 class="text-danger">Đơn hàng đã bị hủy</h6>
                                    <p class="text-muted small">Đơn hàng không được xử lý</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="mt-4 text-center">
                <a asp-action="ChiTiet" asp-route-id="@Model.MaDonHang" class="btn btn-primary">
                    <i class="bi bi-eye"></i> Xem chi tiết đơn hàng
                </a>
                <a asp-action="DanhSach" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .timeline {
            position: relative;
            padding: 20px 0;
        }
        .step {
            display: flex;
            margin-bottom: 30px;
            position: relative;
            opacity: 0.5;
        }
        .step.active {
            opacity: 1;
        }
        .step-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: #e9ecef;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin-right: 20px;
            flex-shrink: 0;
        }
        .step.active .step-icon {
            background: #0d6efd;
            color: white;
        }
        .step-content h6 {
            margin-bottom: 5px;
        }
        .step::before {
            content: '';
            position: absolute;
            left: 25px;
            top: 50px;
            width: 2px;
            height: calc(100% + 30px);
            background: #e9ecef;
        }
        .step:last-child::before {
            display: none;
        }
        .step.active::before {
            background: #0d6efd;
        }
    </style>
}
