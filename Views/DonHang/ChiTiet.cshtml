@model QL_NhaThuoc.Models.DonHang
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="container my-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="DanhSach">Đơn hàng</a></li>
            <li class="breadcrumb-item active">Chi tiết #@Model.MaDonHang</li>
        </ol>
    </nav>

    <h1 class="mb-4"><i class="bi bi-receipt"></i> Chi tiết đơn hàng #@Model.MaDonHang</h1>

    @if (TempData["ThongBao"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle"></i> @TempData["ThongBao"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["LoiThongBao"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-circle"></i> @TempData["LoiThongBao"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-info-circle"></i> Thông tin đơn hàng</h5></div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-sm-4"><strong>Mã đơn hàng:</strong></div>
                        <div class="col-sm-8">#@Model.MaDonHang</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4"><strong>Ngày đặt:</strong></div>
                        <div class="col-sm-8">@Model.NgayDatHang.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4"><strong>Trạng thái:</strong></div>
                        <div class="col-sm-8">
                            @switch (Model.TrangThai)
                            {
                                case "Cho xu ly":
                                    <span class="badge bg-warning">Chờ xử lý</span>
                                    break;
                                case "Dang giao":
                                    <span class="badge bg-info">Đang giao</span>
                                    break;
                                case "Hoan thanh":
                                    <span class="badge bg-success">Hoàn thành</span>
                                    break;
                                case "Da huy":
                                    <span class="badge bg-danger">Đã hủy</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@Model.TrangThai</span>
                                    break;
                            }
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4"><strong>Thanh toán:</strong></div>
                        <div class="col-sm-8">@Model.PhuongThucThanhToan</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-4"><strong>Địa chỉ giao:</strong></div>
                        <div class="col-sm-8">@Model.DiaChiGiaoHang</div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-box"></i> Sản phẩm đã đặt</h5></div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-center">SL</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.ChiTietDonHangs != null)
                                {
                                    @foreach (var ct in Model.ChiTietDonHangs)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <img src="@(ct.Thuoc?.HinhAnh ?? "/images/no-image.svg")" style="width:50px;height:50px;object-fit:contain;" onerror="this.src='/images/no-image.svg'">
                                                    <a asp-controller="Thuoc" asp-action="ChiTiet" asp-route-id="@ct.MaThuoc">@(ct.Thuoc?.TenThuoc ?? "Sản phẩm")</a>
                                                </div>
                                            </td>
                                            <td class="text-end">@ct.DonGia?.ToString("N0")đ</td>
                                            <td class="text-center">@ct.SoLuong</td>
                                            <td class="text-end"><strong class="text-danger">@ct.ThanhTien?.ToString("N0")đ</strong></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white"><h5 class="mb-0">Tổng đơn hàng</h5></div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span>Tạm tính:</span>
                        <strong>@Model.TongTien?.ToString("N0")đ</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Phí ship:</span>
                        <strong class="text-success">Miễn phí</strong>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <strong>Tổng cộng:</strong>
                        <strong class="text-danger fs-5">@Model.TongTien?.ToString("N0")đ</strong>
                    </div>
                </div>
            </div>

            @if (Model.TrangThai == "Cho xu ly")
            {
                <form asp-action="HuyDon" method="post" onsubmit="return confirm('Bạn có chắc muốn hủy đơn hàng này?')">
                    <input type="hidden" name="id" value="@Model.MaDonHang" />
                    <button type="submit" class="btn btn-danger w-100 mb-2">
                        <i class="bi bi-x-circle"></i> Hủy đơn hàng
                    </button>
                </form>
            }

            <a asp-action="TheoDoi" asp-route-id="@Model.MaDonHang" class="btn btn-info w-100 mb-2">
                <i class="bi bi-truck"></i> Theo dõi đơn hàng
            </a>
            <a asp-action="DanhSach" class="btn btn-outline-secondary w-100">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách
            </a>
        </div>
    </div>
</div>
