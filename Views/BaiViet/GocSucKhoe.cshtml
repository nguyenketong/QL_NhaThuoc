@model IEnumerable<QL_NhaThuoc.Models.BaiViet>
@{
    ViewData["Title"] = "Góc Sức Khỏe";
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var totalItems = (int)ViewBag.TotalItems;
}

<!-- Breadcrumb -->
<section class="bg-light py-3">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item active">Góc sức khỏe</li>
            </ol>
        </nav>
    </div>
</section>

<!-- Header -->
<section class="py-4">
    <div class="container">
        <div class="text-center mb-4">
            <h2 class="text-primary fw-bold">GÓC SỨC KHỎE</h2>
            <p class="text-muted">Chia sẻ kiến thức y tế, sức khỏe và chăm sóc bản thân</p>
            <div class="title-divider mx-auto"></div>
        </div>
    </div>
</section>

<!-- Danh sách bài viết -->
<section class="pb-5">
    <div class="container">
        @if (Model.Any())
        {
            <div class="row row-cols-1 row-cols-md-2 g-4">
                @foreach (var baiViet in Model)
                {
                    <div class="col">
                        <div class="article-card d-flex">
                            <div class="article-img">
                                <a asp-action="ChiTiet" asp-route-id="@baiViet.MaBaiViet">
                                    @if (!string.IsNullOrEmpty(baiViet.HinhAnh))
                                    {
                                        <img src="@baiViet.HinhAnh" alt="@baiViet.TieuDe" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                        <div class="article-img-placeholder" style="display:none;">
                                            <i class="fas fa-newspaper fa-2x text-primary"></i>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="article-img-placeholder">
                                            <i class="fas fa-newspaper fa-2x text-primary"></i>
                                        </div>
                                    }
                                </a>
                            </div>
                            <div class="article-content">
                                <div class="article-meta">
                                    <span><i class="far fa-calendar-alt"></i> @(baiViet.NgayDang?.ToString("dd/MM/yyyy") ?? "-")</span>
                                    <span><i class="far fa-eye"></i> @(baiViet.LuotXem ?? 0) lượt xem</span>
                                </div>
                                <h5 class="article-title">
                                    <a asp-action="ChiTiet" asp-route-id="@baiViet.MaBaiViet">@baiViet.TieuDe</a>
                                </h5>
                                <p class="article-desc">
                                    @(baiViet.MoTaNgan?.Length > 120 ? baiViet.MoTaNgan.Substring(0, 120) + "..." : baiViet.MoTaNgan)
                                </p>
                                <a asp-action="ChiTiet" asp-route-id="@baiViet.MaBaiViet" class="btn btn-sm btn-outline-primary">
                                    Xem thêm <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Phân trang -->
            @if (totalPages > 1)
            {
                <nav class="mt-5">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                        <div class="text-muted">
                            Trang @currentPage/@totalPages (Tổng @totalItems bài viết)
                        </div>
                        <ul class="pagination mb-0">
                            <!-- Đầu tiên -->
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="GocSucKhoe" asp-route-page="1">
                                    <i class="fas fa-angle-double-left"></i> Đầu
                                </a>
                            </li>
                            <!-- Trước -->
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="GocSucKhoe" asp-route-page="@(currentPage - 1)">
                                    <i class="fas fa-angle-left"></i> Trước
                                </a>
                            </li>
                            
                            <!-- Số trang -->
                            @{
                                var startPage = Math.Max(1, currentPage - 2);
                                var endPage = Math.Min(totalPages, currentPage + 2);
                            }
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" asp-action="GocSucKhoe" asp-route-page="@i">@i</a>
                                </li>
                            }
                            
                            <!-- Kế tiếp -->
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="GocSucKhoe" asp-route-page="@(currentPage + 1)">
                                    Kế tiếp <i class="fas fa-angle-right"></i>
                                </a>
                            </li>
                            <!-- Cuối cùng -->
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="GocSucKhoe" asp-route-page="@totalPages">
                                    Cuối <i class="fas fa-angle-double-right"></i>
                                </a>
                            </li>
                        </ul>
                    </div>
                </nav>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-newspaper fa-4x text-muted mb-3"></i>
                <h5 class="text-muted">Chưa có bài viết nào</h5>
            </div>
        }
    </div>
</section>

<style>
.title-divider {
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, #1a8ccc, #0d6efd);
    margin-top: 15px;
}

/* Article Card */
.article-card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 15px rgba(0,0,0,0.08);
    transition: all 0.3s;
    height: 100%;
}
.article-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 5px 25px rgba(0,0,0,0.12);
}
.article-img {
    flex-shrink: 0;
    width: 180px;
    min-height: 160px;
    background: #f8f9fa;
}
.article-img img {
    width: 100%;
    height: 100%;
    min-height: 160px;
    object-fit: cover;
}
.article-img-placeholder {
    width: 100%;
    height: 100%;
    min-height: 160px;
    background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
    display: flex;
    align-items: center;
    justify-content: center;
}
.article-content {
    padding: 15px;
    display: flex;
    flex-direction: column;
}
.article-meta {
    display: flex;
    gap: 15px;
    font-size: 12px;
    color: #888;
    margin-bottom: 8px;
}
.article-meta i {
    margin-right: 4px;
}
.article-title {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
    line-height: 1.4;
}
.article-title a {
    color: #333;
    text-decoration: none;
}
.article-title a:hover {
    color: #1a8ccc;
}
.article-desc {
    font-size: 13px;
    color: #666;
    margin-bottom: 10px;
    flex-grow: 1;
}

/* Pagination */
.pagination .page-link {
    border-radius: 8px;
    margin: 0 3px;
    border: none;
    color: #333;
    padding: 8px 14px;
}
.pagination .page-item.active .page-link {
    background: #1a8ccc;
    color: #fff;
}
.pagination .page-link:hover {
    background: #e9ecef;
}
.pagination .page-item.disabled .page-link {
    color: #ccc;
}

@@media (max-width: 576px) {
    .article-card {
        flex-direction: column;
    }
    .article-img {
        width: 100%;
        height: 180px;
    }
}
</style>
