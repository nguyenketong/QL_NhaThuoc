@model QL_NhaThuoc.Models.Product
@{
    ViewData["Title"] = Model?.Name ?? "Chi tiết sản phẩm";
}

<div class="container py-5">
    @if (Model != null)
    {
        <div class="row">
            <div class="col-md-5">
                <div class="product-detail-image">
                    <img src="@(Model.ImageUrl ?? "https://via.placeholder.com/500x500?text=Product")" 
                         alt="@Model.Name" class="img-fluid rounded" />
                </div>
            </div>
            <div class="col-md-7">
                <h2 class="mb-3">@Model.Name</h2>
                <div class="mb-3">
                    <span class="badge bg-primary">@Model.Category?.Name</span>
                    <span class="badge bg-secondary">@Model.Brand?.Name</span>
                </div>
                <div class="product-price mb-4">
                    <h3 class="text-danger">@Model.Price.ToString("N0")đ</h3>
                </div>
                <div class="mb-3">
                    <p><strong>Xuất xứ:</strong> @Model.Country?.Name</p>
                    <p><strong>Đối tượng sử dụng:</strong> @Model.UsageObject?.Name</p>
                    <p><strong>Tình trạng:</strong> 
                        @if (Model.StockQuantity > 0)
                        {
                            <span class="text-success">Còn hàng (@Model.StockQuantity)</span>
                        }
                        else
                        {
                            <span class="text-danger">Hết hàng</span>
                        }
                    </p>
                </div>
                <div class="mb-4">
                    <label class="form-label">Số lượng:</label>
                    <div class="input-group w-25">
                        <button class="btn btn-outline-secondary" type="button">-</button>
                        <input type="number" class="form-control text-center" value="1" min="1" />
                        <button class="btn btn-outline-secondary" type="button">+</button>
                    </div>
                </div>
                <div class="d-flex gap-3">
                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex-fill">
                        <input type="hidden" name="productId" value="@Model.ProductId" />
                        <input type="hidden" name="quantity" value="1" />
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="fas fa-cart-plus"></i> Thêm vào giỏ hàng
                        </button>
                    </form>
                    <button class="btn btn-outline-danger btn-lg">
                        <i class="fas fa-heart"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="row mt-5">
            <div class="col-12">
                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#description">Mô tả</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#ingredients">Thành phần</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#sideeffects">Tác dụng phụ</a>
                    </li>
                </ul>
                <div class="tab-content p-4 border border-top-0">
                    <div id="description" class="tab-pane active">
                        <p>@(Model.Description ?? "Chưa có mô tả")</p>
                    </div>
                    <div id="ingredients" class="tab-pane fade">
                        @if (Model.ProductIngredients?.Any() == true)
                        {
                            <ul>
                                @foreach (var pi in Model.ProductIngredients)
                                {
                                    <li>@pi.Ingredient?.Name - @pi.Quantity</li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p>Chưa có thông tin thành phần</p>
                        }
                    </div>
                    <div id="sideeffects" class="tab-pane fade">
                        @if (Model.ProductSideEffects?.Any() == true)
                        {
                            <ul>
                                @foreach (var ps in Model.ProductSideEffects)
                                {
                                    <li>@ps.SideEffect?.Name</li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p>Chưa có thông tin tác dụng phụ</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
