@model List<QL_NhaThuoc.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm";
}

<div class="container py-5">
    <div class="row">
        <!-- Sidebar Filter -->
        <div class="col-md-3">
            <div class="filter-sidebar">
                <h5 class="mb-3">Bộ lọc</h5>
                
                <div class="filter-group mb-4">
                    <h6>Danh mục</h6>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="cat1">
                        <label class="form-check-label" for="cat1">Thuốc giảm đau</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="cat2">
                        <label class="form-check-label" for="cat2">Thuốc cảm cúm</label>
                    </div>
                </div>

                <div class="filter-group mb-4">
                    <h6>Khoảng giá</h6>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="price" id="price1">
                        <label class="form-check-label" for="price1">Dưới 50.000đ</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="price" id="price2">
                        <label class="form-check-label" for="price2">50.000đ - 100.000đ</label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Products Grid -->
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4>Tất cả sản phẩm</h4>
                <select class="form-select w-auto">
                    <option>Sắp xếp theo</option>
                    <option>Giá tăng dần</option>
                    <option>Giá giảm dần</option>
                    <option>Tên A-Z</option>
                </select>
            </div>

            <div class="row g-4">
                @if (Model != null && Model.Any())
                {
                    @foreach (var product in Model)
                    {
                        <div class="col-md-4">
                            <div class="product-card">
                                <div class="product-image">
                                    <img src="@(product.ImageUrl ?? "https://via.placeholder.com/250x250?text=Product")" alt="@product.Name" />
                                </div>
                                <div class="product-info">
                                    <h6 class="product-name">@product.Name</h6>
                                    <div class="product-price">
                                        <span class="price-new">@product.Price.ToString("N0")đ</span>
                                    </div>
                                    <div class="d-flex gap-2 mt-2">
                                        <a asp-action="Details" asp-route-id="@product.ProductId" class="btn btn-outline-primary btn-sm flex-fill">Chi tiết</a>
                                        <button class="btn btn-primary btn-sm flex-fill">
                                            <i class="fas fa-cart-plus"></i> Thêm
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                        <p>Chưa có sản phẩm nào</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
