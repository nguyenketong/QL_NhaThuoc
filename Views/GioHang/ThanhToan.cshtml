@model List<QL_NhaThuoc.Controllers.GioHangController.GioHangItem>
@{
    ViewData["Title"] = "Thanh toán";
    var tongTien = Model.Sum(g => g.ThanhTien);
}

<div class="container my-4">
    <h1 class="mb-4">
        <i class="bi bi-credit-card"></i> Thanh toán đơn hàng
    </h1>

    @if (TempData["LoiThongBao"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-circle"></i> @TempData["LoiThongBao"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-8">
            <form asp-action="XuLyThanhToan" method="post">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Thông tin giao hàng</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Họ và tên</label>
                            <input type="text" class="form-control" value="@Context.Session.GetString("HoTen")" readonly>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Số điện thoại</label>
                            <input type="text" class="form-control" value="@Context.Session.GetString("SoDienThoai")" readonly>
                        </div>
                        <div class="mb-3">
                            <label for="diaChiGiaoHang" class="form-label">Địa chỉ giao hàng <span class="text-danger">*</span></label>
                            <textarea id="diaChiGiaoHang" name="diaChiGiaoHang" class="form-control" rows="3" required 
                                      placeholder="Nhập địa chỉ chi tiết để giao hàng"></textarea>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Phương thức thanh toán</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="radio" name="phuongThucThanhToan" 
                                   id="tienMat" value="Tiền mặt" checked>
                            <label class="form-check-label" for="tienMat">
                                <i class="bi bi-cash"></i> Thanh toán khi nhận hàng (COD)
                            </label>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="radio" name="phuongThucThanhToan" 
                                   id="chuyenKhoan" value="Chuyển khoản">
                            <label class="form-check-label" for="chuyenKhoan">
                                <i class="bi bi-bank"></i> Chuyển khoản ngân hàng
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="phuongThucThanhToan" 
                                   id="viDienTu" value="Ví điện tử">
                            <label class="form-check-label" for="viDienTu">
                                <i class="bi bi-wallet2"></i> Ví điện tử (Momo, ZaloPay)
                            </label>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại giỏ hàng
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle"></i> Đặt hàng
                    </button>
                </div>
            </form>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Đơn hàng của bạn</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        @foreach (var item in Model)
                        {
                            <div class="d-flex justify-content-between mb-2">
                                <div>
                                    <strong>@item.TenThuoc</strong>
                                    <br>
                                    <small class="text-muted">x @item.SoLuong</small>
                                </div>
                                <div class="text-end">
                                    @item.ThanhTien.ToString("N0") đ
                                </div>
                            </div>
                            <hr>
                        }
                    </div>
                    
                    <div class="d-flex justify-content-between mb-2">
                        <span>Tạm tính:</span>
                        <strong>@tongTien.ToString("N0") đ</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Phí vận chuyển:</span>
                        <strong>Miễn phí</strong>
                    </div>
                    <hr>
                    <div class="d-flex justify-content-between">
                        <strong>Tổng cộng:</strong>
                        <strong class="text-danger fs-4">@tongTien.ToString("N0") đ</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
