@model QL_NhaThuoc.Models.ThuongHieu
@{
    ViewData["Title"] = Model?.TenThuongHieu ?? "Chi tiết thương hiệu";
    var currentPage = ViewBag.CurrentPage ?? 1;
    var totalPages = ViewBag.TotalPages ?? 1;
    var totalItems = ViewBag.TotalItems ?? 0;
    var sapXep = ViewBag.SapXep as string;
}

<div class="container my-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none"><i class="fas fa-home"></i> Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="DanhSach" class="text-decoration-none">Thương hiệu</a></li>
            <li class="breadcrumb-item active">@Model?.TenThuongHieu</li>
        </ol>
    </nav>

    <!-- Brand Header -->
    <div class="brand-header mb-4">
        <div class="row align-items-center">
            <div class="col-auto">
                @if (!string.IsNullOrEmpty(Model?.HinhAnh))
                {
                    <img src="@Model.HinhAnh" alt="@Model.TenThuongHieu" class="brand-logo-large">
                }
                else
                {
                    <div class="brand-logo-placeholder">
                        <i class="fas fa-building fa-3x text-primary"></i>
                    </div>
                }
            </div>
            <div class="col">
                <h1 class="brand-title mb-2">@Model?.TenThuongHieu</h1>
                @if (!string.IsNullOrEmpty(Model?.QuocGia))
                {
                    <p class="text-muted mb-1"><i class="fas fa-globe me-2"></i>@Model.QuocGia</p>
                }
                @if (!string.IsNullOrEmpty(Model?.DiaChi))
                {
                    <p class="text-muted mb-0"><i class="fas fa-map-marker-alt me-2"></i>@Model.DiaChi</p>
                }
            </div>
            <div class="col-auto">
                <span class="badge bg-primary fs-6 px-3 py-2">
                    <i class="fas fa-box me-1"></i> @totalItems sản phẩm
                </span>
            </div>
        </div>
    </div>

    @if (Model?.Thuocs != null && Model.Thuocs.Any())
    {
        <!-- Filter Bar -->
        <div class="filter-bar bg-light rounded p-3 mb-4">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <span class="text-muted">
                        Hiển thị @((currentPage - 1) * 12 + 1) - @Math.Min(currentPage * 12, totalItems) trong @totalItems sản phẩm
                    </span>
                </div>
                <div class="col-md-6 text-md-end mt-2 mt-md-0">
                    <div class="d-inline-flex align-items-center">
                        <label class="me-2 text-muted">Sắp xếp:</label>
                        <select class="form-select form-select-sm" style="width: auto;" onchange="sortProducts(this.value)" id="sortSelect">
                            <option value="">Mặc định</option>
                            <option value="moi-nhat">Mới nhất</option>
                            <option value="gia-tang">Giá tăng dần</option>
                            <option value="gia-giam">Giá giảm dần</option>
                            <option value="ten-az">Tên A-Z</option>
                            <option value="ten-za">Tên Z-A</option>
                        </select>
                        <script>document.getElementById('sortSelect').value = '@(sapXep ?? "")';</script>
                    </div>
                </div>
            </div>
        </div>

        <!-- Products Grid -->
        <div class="row g-3">
            @foreach (var thuoc in Model.Thuocs)
            {
                var giaBan = thuoc.GiaBan ?? 0;
                var phanTramGiam = (thuoc.PhanTramGiam.HasValue && thuoc.PhanTramGiam.Value > 0) 
                    ? thuoc.PhanTramGiam.Value : 0;
                var giaGoc = thuoc.GiaGoc ?? (phanTramGiam > 0 ? Math.Ceiling(giaBan * 100 / (100 - phanTramGiam)) : giaBan);
                if (phanTramGiam == 0 && giaGoc > giaBan && giaGoc > 0)
                {
                    phanTramGiam = (int)((giaGoc - giaBan) * 100 / giaGoc);
                }
                var isHot = thuoc.IsHot ?? false;
                var isNew = thuoc.IsNew ?? false;

                <div class="col-6 col-md-4 col-lg-3 col-xl-2-4">
                    <div class="product-card-compact">
                        <div class="product-badges">
                            @if (phanTramGiam > 0)
                            {
                                <span class="badge-discount">-@phanTramGiam%</span>
                            }
                            @if (isHot)
                            {
                                <span class="badge-hot">HOT</span>
                            }
                            @if (isNew)
                            {
                                <span class="badge-new">Mới</span>
                            }
                        </div>
                        <a asp-controller="Thuoc" asp-action="ChiTiet" asp-route-id="@thuoc.MaThuoc" class="product-image-link">
                            <img src="@(string.IsNullOrEmpty(thuoc.HinhAnh) ? "/images/no-image.svg" : thuoc.HinhAnh)"
                                 alt="@thuoc.TenThuoc" class="product-image-compact"
                                 onerror="this.src='/images/no-image.svg'">
                        </a>
                        <div class="product-info-compact">
                            <a asp-controller="Thuoc" asp-action="ChiTiet" asp-route-id="@thuoc.MaThuoc" class="product-name-compact">
                                @thuoc.TenThuoc
                            </a>
                            <div class="product-price-compact">
                                <span class="price-current">@giaBan.ToString("N0")đ</span>
                                @if (phanTramGiam > 0 && giaGoc > giaBan)
                                {
                                    <span class="price-original">@giaGoc.ToString("N0")đ</span>
                                }
                            </div>
                            <div class="product-actions-compact">
                                <a asp-controller="Thuoc" asp-action="ChiTiet" asp-route-id="@thuoc.MaThuoc" class="btn-detail-compact">
                                    <i class="fas fa-eye"></i> Chi tiết
                                </a>
                                <button type="button" class="btn-cart-compact" onclick="themVaoGioHang(@thuoc.MaThuoc)">
                                    <i class="fas fa-cart-plus"></i> Thêm giỏ
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="ChiTiet" asp-route-id="@Model.MaThuongHieu" asp-route-page="@(currentPage - 1)" asp-route-sapXep="@sapXep">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        if (i == 1 || i == totalPages || (i >= currentPage - 2 && i <= currentPage + 2))
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link" asp-action="ChiTiet" asp-route-id="@Model.MaThuongHieu" asp-route-page="@i" asp-route-sapXep="@sapXep">@i</a>
                            </li>
                        }
                        else if (i == currentPage - 3 || i == currentPage + 3)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="ChiTiet" asp-route-id="@Model.MaThuongHieu" asp-route-page="@(currentPage + 1)" asp-route-sapXep="@sapXep">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="empty-state text-center py-5">
            <div class="empty-icon mb-4">
                <i class="fas fa-box-open fa-5x text-muted"></i>
            </div>
            <h3 class="text-muted mb-3">Chưa có sản phẩm</h3>
            <p class="text-muted mb-4">Thương hiệu "@Model?.TenThuongHieu" hiện chưa có sản phẩm nào.</p>
            <div class="d-flex justify-content-center gap-3">
                <a asp-action="DanhSach" class="btn btn-outline-primary">
                    <i class="fas fa-building me-2"></i>Xem thương hiệu khác
                </a>
                <a asp-controller="Thuoc" asp-action="DanhSach" class="btn btn-primary">
                    <i class="fas fa-pills me-2"></i>Xem tất cả sản phẩm
                </a>
            </div>
        </div>
    }
</div>

<script>
function sortProducts(value) {
    var url = new URL(window.location.href);
    if (value) {
        url.searchParams.set('sapXep', value);
    } else {
        url.searchParams.delete('sapXep');
    }
    url.searchParams.set('page', '1');
    window.location.href = url.toString();
}

function themVaoGioHang(maThuoc) {
    fetch('/GioHang/ThemSanPham', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ maThuoc: maThuoc, soLuong: 1 })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            document.getElementById('cart-count').textContent = data.soLuong;
            alert('Đã thêm sản phẩm vào giỏ hàng!');
        } else {
            alert(data.message || 'Có lỗi xảy ra!');
        }
    })
    .catch(() => alert('Có lỗi xảy ra!'));
}
</script>

<style>
.brand-header {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    padding: 25px;
    border-radius: 12px;
    border-left: 4px solid #1a8ccc;
}
.brand-logo-large {
    max-width: 150px;
    max-height: 80px;
    object-fit: contain;
}
.brand-logo-placeholder {
    width: 150px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border-radius: 8px;
}
.brand-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #333;
}
.filter-bar { border: 1px solid #dee2e6; }
.product-card-compact { background: #fff; border-radius: 10px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); transition: all 0.3s ease; height: 100%; display: flex; flex-direction: column; position: relative; }
.product-card-compact:hover { transform: translateY(-5px); box-shadow: 0 8px 25px rgba(0,0,0,0.15); }
.product-badges { position: absolute; top: 8px; left: 8px; z-index: 10; display: flex; flex-direction: column; gap: 4px; }
.badge-discount { background: #dc3545; color: #fff; padding: 3px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
.badge-hot { background: #ff6b35; color: #fff; padding: 3px 8px; border-radius: 4px; font-size: 10px; font-weight: 600; }
.badge-new { background: #28a745; color: #fff; padding: 3px 8px; border-radius: 4px; font-size: 10px; font-weight: 600; }
.product-image-link { display: block; padding: 15px; background: #f8f9fa; }
.product-image-compact { width: 100%; height: 140px; object-fit: contain; transition: transform 0.3s; }
.product-card-compact:hover .product-image-compact { transform: scale(1.05); }
.product-info-compact { padding: 12px; flex: 1; display: flex; flex-direction: column; }
.product-name-compact { font-size: 13px; font-weight: 600; color: #333; text-decoration: none; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4; min-height: 36px; margin-bottom: 8px; }
.product-name-compact:hover { color: #1a8ccc; }
.product-price-compact { margin-bottom: 10px; }
.price-current { font-size: 15px; font-weight: 700; color: #dc3545; }
.price-original { font-size: 12px; color: #999; text-decoration: line-through; margin-left: 6px; }
.product-actions-compact { display: flex; gap: 6px; margin-top: auto; }
.btn-detail-compact, .btn-cart-compact { flex: 1; padding: 6px 8px; font-size: 11px; border-radius: 5px; border: none; cursor: pointer; transition: all 0.2s; text-align: center; text-decoration: none; }
.btn-detail-compact { background: #e9ecef; color: #333; }
.btn-detail-compact:hover { background: #1a8ccc; color: #fff; }
.btn-cart-compact { background: #28a745; color: #fff; }
.btn-cart-compact:hover { background: #218838; }
.empty-state { background: #f8f9fa; border-radius: 15px; padding: 60px 20px; }
@@media (min-width: 1200px) { .col-xl-2-4 { flex: 0 0 20%; max-width: 20%; } }
</style>
