@{
    ViewData["Title"] = "Danh sách nhóm thuốc";
}

<div class="container my-4">
    <h1 class="mb-4">Danh sách nhóm thuốc</h1>

    <div class="row">
        @if (Model != null)
        {
            var items = Model as IEnumerable<dynamic>;
            @foreach (var item in items)
            {
                <div class="col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@item.TenNhomThuoc</h5>
                            @if (!string.IsNullOrEmpty((string)item.MoTa))
                            {
                                <p class="card-text text-muted small">@item.MoTa</p>
                            }
                            <div class="mt-3">
                                <span class="badge bg-info">@item.SoLuongThuoc sản phẩm</span>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a asp-action="ChiTiet" asp-route-id="@item.MaNhomThuoc" 
                               class="btn btn-primary btn-sm w-100">
                                <i class="bi bi-eye"></i> Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
            
            @if (!items.Any())
            {
                <div class="col-12">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> Chưa có nhóm thuốc nào.
                    </div>
                </div>
            }
        }
    </div>
</div>
