@model IEnumerable<QL_NhaThuoc.Models.NhomThuoc>
@{
    ViewData["Title"] = "Danh mục sản phẩm";
}

<div class="container my-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active">Danh mục sản phẩm</li>
        </ol>
    </nav>

    <h2 class="text-primary fw-bold mb-4">
        <i class="fas fa-th-list me-2"></i>Danh mục sản phẩm
    </h2>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var nhomCha in Model)
            {
                var soLuong = ViewData[$"SoLuong_{nhomCha.MaNhomThuoc}"] ?? 0;
                var danhMucCon = nhomCha.DanhMucCon?.ToList() ?? new List<QL_NhaThuoc.Models.NhomThuoc>();
                
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 category-card">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0 text-white">
                                <i class="fas fa-folder me-2"></i>@nhomCha.TenNhomThuoc
                            </h5>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(nhomCha.MoTa))
                            {
                                <p class="text-muted small mb-3">@nhomCha.MoTa</p>
                            }
                            
                            @if (danhMucCon.Any())
                            {
                                <div class="subcategory-list">
                                    <p class="fw-bold text-secondary mb-2">
                                        <i class="fas fa-folder-open me-1"></i> Danh mục con:
                                    </p>
                                    <ul class="list-unstyled ms-2">
                                        @foreach (var con in danhMucCon)
                                        {
                                            <li class="mb-2">
                                                <a asp-action="ChiTiet" asp-route-id="@con.MaNhomThuoc" 
                                                   class="text-decoration-none subcategory-link">
                                                    <i class="fas fa-angle-right text-primary me-1"></i>
                                                    @con.TenNhomThuoc
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            }
                            
                            <div class="mt-3">
                                <span class="badge bg-info">
                                    <i class="fas fa-pills me-1"></i>@soLuong sản phẩm
                                </span>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0">
                            <a asp-action="ChiTiet" asp-route-id="@nhomCha.MaNhomThuoc" 
                               class="btn btn-outline-primary w-100">
                                <i class="fas fa-eye me-1"></i> Xem tất cả sản phẩm
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i> Chưa có danh mục sản phẩm nào.
        </div>
    }
</div>

<style>
    .category-card {
        transition: transform 0.3s, box-shadow 0.3s;
    }
    .category-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
    }
    .subcategory-link {
        color: #333;
        transition: color 0.2s, padding-left 0.2s;
    }
    .subcategory-link:hover {
        color: #0d6efd;
        padding-left: 5px;
    }
    .subcategory-list {
        max-height: 200px;
        overflow-y: auto;
    }
</style>
