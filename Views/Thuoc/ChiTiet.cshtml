@model QL_NhaThuoc.Models.Thuoc
@{
    ViewData["Title"] = Model.TenThuoc;
    var ngungKinhDoanh = Model.IsActive != true; // Chỉ kinh doanh khi IsActive = true
}

<div class="container my-5">
    <!-- Thông báo ngừng kinh doanh -->
    @if (ngungKinhDoanh)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="fas fa-ban me-2"></i>
            <strong>Sản phẩm đã ngừng kinh doanh!</strong> Sản phẩm này hiện không còn được bán. Vui lòng chọn sản phẩm khác.
        </div>
    }

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-controller="Thuoc" asp-action="DanhSach">Sản phẩm</a></li>
            @if (Model.NhomThuoc != null)
            {
                <li class="breadcrumb-item">
                    <a asp-controller="Thuoc" asp-action="TheoNhom" asp-route-id="@Model.MaNhomThuoc">@Model.NhomThuoc.TenNhomThuoc</a>
                </li>
            }
            <li class="breadcrumb-item active">@Model.TenThuoc</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Hình ảnh -->
        <div class="col-md-5">
            <div class="card">
                <div class="card-body text-center">
                    <img src="@(string.IsNullOrEmpty(Model.HinhAnh) ? "/images/no-image.svg" : Model.HinhAnh)" 
                         alt="@Model.TenThuoc" class="img-fluid" style="max-height: 400px;"
                         onerror="this.src='/images/no-image.svg'" />
                </div>
            </div>
        </div>

        <!-- Thông tin -->
        <div class="col-md-7">
            <h2 class="mb-3">@Model.TenThuoc</h2>
            
            <div class="mb-3">
                @if (Model.NhomThuoc != null)
                {
                    <span class="badge bg-primary me-2">@Model.NhomThuoc.TenNhomThuoc</span>
                }
                @if (Model.ThuongHieu != null)
                {
                    <span class="badge bg-secondary">@Model.ThuongHieu.TenThuongHieu</span>
                }
            </div>

            @{
                var giaBan = Model.GiaBan ?? 0;
                var phanTramGiam = (Model.PhanTramGiam.HasValue && Model.PhanTramGiam.Value > 0) 
                    ? Model.PhanTramGiam.Value : 0;
                var giaGoc = Model.GiaGoc ?? (phanTramGiam > 0 ? Math.Ceiling(giaBan * 100 / (100 - phanTramGiam)) : giaBan);
                if (phanTramGiam == 0 && giaGoc > giaBan && giaGoc > 0)
                {
                    phanTramGiam = (int)((giaGoc - giaBan) * 100 / giaGoc);
                }
            }
            <div class="card mb-3">
                <div class="card-body">
                    @if (phanTramGiam > 0)
                    {
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="badge bg-danger fs-6">-@phanTramGiam%</span>
                            @if (Model.IsHot == true)
                            {
                                <span class="badge bg-warning text-dark">🔥 HOT</span>
                            }
                            @if (Model.IsNew == true)
                            {
                                <span class="badge bg-success">🆕 Mới</span>
                            }
                        </div>
                        <h3 class="text-danger mb-0">@giaBan.ToString("N0")đ</h3>
                        <span class="text-muted text-decoration-line-through">@giaGoc.ToString("N0")đ</span>
                    }
                    else
                    {
                        <h3 class="text-danger mb-0">@giaBan.ToString("N0")đ</h3>
                    }
                    <small class="text-muted">/@(Model.DonViTinh ?? "Hộp")</small>
                </div>
            </div>

            @{
                var soLuongTon = Model.SoLuongTon ?? 0;
                var soLuongDaBan = Model.SoLuongDaBan ?? 0;
                var hetHang = soLuongTon <= 0;
                // Kiểm tra khuyến mãi còn hiệu lực
                var dangKhuyenMai = phanTramGiam > 0 
                    && (!Model.NgayBatDauKM.HasValue || Model.NgayBatDauKM <= DateTime.Now)
                    && (!Model.NgayKetThucKM.HasValue || Model.NgayKetThucKM >= DateTime.Now);
            }
            
            <!-- Thông tin khuyến mãi -->
            @if (dangKhuyenMai && (Model.NgayBatDauKM.HasValue || Model.NgayKetThucKM.HasValue))
            {
                <div class="alert alert-warning mb-3">
                    <i class="fas fa-clock"></i> <strong>Khuyến mãi:</strong>
                    @if (Model.NgayBatDauKM.HasValue)
                    {
                        <span>Từ @Model.NgayBatDauKM.Value.ToString("dd/MM/yyyy")</span>
                    }
                    @if (Model.NgayKetThucKM.HasValue)
                    {
                        <span>đến @Model.NgayKetThucKM.Value.ToString("dd/MM/yyyy")</span>
                    }
                </div>
            }

            <table class="table table-bordered">
                <tr>
                    <th width="30%">Thương hiệu</th>
                    <td>@(Model.ThuongHieu?.TenThuongHieu ?? "Đang cập nhật")</td>
                </tr>
                <tr>
                    <th>Xuất xứ</th>
                    <td>@(Model.NuocSanXuat?.TenNuocSX ?? "Đang cập nhật")</td>
                </tr>
                <tr>
                    <th>Đơn vị tính</th>
                    <td>@(Model.DonViTinh ?? "Hộp")</td>
                </tr>
                <tr>
                    <th>Tình trạng</th>
                    <td>
                        @if (hetHang)
                        {
                            <span class="badge bg-danger">Hết hàng</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Còn @soLuongTon sản phẩm</span>
                        }
                    </td>
                </tr>
                <tr>
                    <th>Đã bán</th>
                    <td><span class="text-primary">@soLuongDaBan sản phẩm</span></td>
                </tr>
            </table>

            <!-- Số lượng và nút mua -->
            @if (ngungKinhDoanh)
            {
                <div class="alert alert-secondary">
                    <i class="fas fa-ban"></i> <strong>Sản phẩm đã ngừng kinh doanh.</strong> Không thể mua sản phẩm này.
                </div>
            }
            else if (hetHang)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle"></i> Sản phẩm hiện đã hết hàng. Vui lòng quay lại sau!
                </div>
            }
            else
            {
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="input-group" style="width: 150px;">
                        <button class="btn btn-outline-secondary" type="button" onclick="giamSoLuong()">-</button>
                        <input type="number" id="soLuong" class="form-control text-center" value="1" min="1" max="@soLuongTon">
                        <button class="btn btn-outline-secondary" type="button" onclick="tangSoLuong()">+</button>
                    </div>
                    <button class="btn btn-primary btn-lg" onclick="themVaoGioHang(@Model.MaThuoc, document.getElementById('soLuong').value)">
                        <i class="fas fa-cart-plus"></i> Thêm vào giỏ hàng
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- Mô tả và thông tin chi tiết -->
    <div class="row mt-4">
        <div class="col-12">
            <ul class="nav nav-tabs" id="productTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#moTa">Mô tả</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#thanhPhan">Thành phần</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tacDungPhu">Tác dụng phụ</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#doiTuong">Đối tượng sử dụng</button>
                </li>
            </ul>
            <div class="tab-content p-4 border border-top-0 rounded-bottom">
                <div class="tab-pane fade show active" id="moTa">
                    @if (!string.IsNullOrEmpty(Model.MoTa))
                    {
                        <p>@Model.MoTa</p>
                    }
                    else
                    {
                        <p class="text-muted">Chưa có mô tả</p>
                    }
                </div>
                <div class="tab-pane fade" id="thanhPhan">
                    @if (Model.CT_ThanhPhans != null && Model.CT_ThanhPhans.Any())
                    {
                        <ul class="list-group">
                            @foreach (var ct in Model.CT_ThanhPhans)
                            {
                                <li class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <strong>@ct.ThanhPhan?.TenThanhPhan</strong>
                                            @if (!string.IsNullOrEmpty(ct.ThanhPhan?.MoTa))
                                            {
                                                <p class="text-muted small mb-0 mt-1">@ct.ThanhPhan.MoTa</p>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(ct.HamLuong))
                                        {
                                            <span class="badge bg-info">@ct.HamLuong</span>
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">Chưa có thông tin thành phần</p>
                    }
                </div>
                <div class="tab-pane fade" id="tacDungPhu">
                    @if (Model.CT_TacDungPhus != null && Model.CT_TacDungPhus.Any())
                    {
                        <ul class="list-group">
                            @foreach (var ct in Model.CT_TacDungPhus)
                            {
                                <li class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <i class="fas fa-exclamation-triangle text-warning me-2"></i>
                                            <strong>@ct.TacDungPhu?.TenTacDungPhu</strong>
                                            @if (!string.IsNullOrEmpty(ct.TacDungPhu?.MoTa))
                                            {
                                                <p class="text-muted small mb-0 mt-1">@ct.TacDungPhu.MoTa</p>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(ct.MucDo))
                                        {
                                            <span class="badge bg-warning text-dark">@ct.MucDo</span>
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">Chưa có thông tin tác dụng phụ</p>
                    }
                </div>
                <div class="tab-pane fade" id="doiTuong">
                    @if (Model.CT_DoiTuongs != null && Model.CT_DoiTuongs.Any())
                    {
                        <ul class="list-group">
                            @foreach (var ct in Model.CT_DoiTuongs)
                            {
                                <li class="list-group-item">
                                    <i class="fas fa-user text-primary me-2"></i>
                                    <strong>@ct.DoiTuongSuDung?.TenDoiTuong</strong>
                                    @if (!string.IsNullOrEmpty(ct.DoiTuongSuDung?.MoTa))
                                    {
                                        <p class="text-muted small mb-0 mt-1">@ct.DoiTuongSuDung.MoTa</p>
                                    }
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">Chưa có thông tin đối tượng sử dụng</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function tangSoLuong() {
        var input = document.getElementById('soLuong');
        input.value = parseInt(input.value) + 1;
    }
    
    function giamSoLuong() {
        var input = document.getElementById('soLuong');
        if (parseInt(input.value) > 1) {
            input.value = parseInt(input.value) - 1;
        }
    }
</script>
}
