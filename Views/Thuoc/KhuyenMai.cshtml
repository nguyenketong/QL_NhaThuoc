@model IEnumerable<QL_NhaThuoc.Models.Thuoc>
@{
    ViewData["Title"] = "Sản phẩm khuyến mãi";
}

<div class="container my-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active">Khuyến mãi</li>
        </ol>
    </nav>

    <div class="text-center mb-4">
        <h1 class="text-danger fw-bold"><i class="fas fa-tags me-2"></i>SẢN PHẨM KHUYẾN MÃI</h1>
        <p class="text-muted">Săn deal hot - Giá siêu hời</p>
    </div>

    @if (Model.Any())
    {
        <div class="row g-3">
            @foreach (var thuoc in Model)
            {
                var phanTramGiam = thuoc.PhanTramGiam ?? 0;
                var isHot = thuoc.IsHot ?? false;
                var isNew = thuoc.IsNew ?? false;
                var ngungKinhDoanh = thuoc.IsActive != true;
                var hetHang = (thuoc.SoLuongTon ?? 0) <= 0;
                var khongKhaDung = ngungKinhDoanh || hetHang;
                var dangKhuyenMai = phanTramGiam > 0 
                    && (!thuoc.NgayBatDauKM.HasValue || thuoc.NgayBatDauKM <= DateTime.Now)
                    && (!thuoc.NgayKetThucKM.HasValue || thuoc.NgayKetThucKM >= DateTime.Now);
                decimal giaGoc = thuoc.GiaGoc ?? thuoc.GiaBan ?? 0;
                decimal giaBan = dangKhuyenMai ? (giaGoc * (100 - phanTramGiam) / 100) : (thuoc.GiaBan ?? 0);
                
                <div class="col-md-3">
                    <div class="product-card position-relative @(khongKhaDung ? "opacity-60" : "")">
                        <div class="product-badges position-absolute" style="top: 10px; left: 10px; z-index: 2;">
                            @if (ngungKinhDoanh)
                            {
                                <span class="badge bg-secondary">Ngừng kinh doanh</span>
                            }
                            else if (hetHang)
                            {
                                <span class="badge bg-dark">Hết hàng</span>
                            }
                            else
                            {
                                @if (phanTramGiam > 0)
                                {
                                    <span class="badge bg-danger">-@phanTramGiam%</span>
                                }
                                @if (isHot)
                                {
                                    <span class="badge bg-warning text-dark">HOT</span>
                                }
                                @if (isNew)
                                {
                                    <span class="badge bg-success">Mới</span>
                                }
                            }
                        </div>
                        <div class="product-image">
                            <img src="@(string.IsNullOrEmpty(thuoc.HinhAnh) ? "/images/no-image.svg" : thuoc.HinhAnh)" 
                                 alt="@thuoc.TenThuoc" onerror="this.src='/images/no-image.svg'" />
                        </div>
                        <div class="product-info">
                            <h6 class="product-name">@thuoc.TenThuoc</h6>
                            <div class="product-category">
                                <small class="text-muted">@(thuoc.NhomThuoc?.TenNhomThuoc ?? "")</small>
                            </div>
                            <div class="product-price">
                                <span class="price-new text-danger fw-bold">@giaBan.ToString("N0")đ</span>
                                @if (phanTramGiam > 0 && giaGoc > giaBan)
                                {
                                    <span class="price-old text-muted text-decoration-line-through ms-2">@giaGoc.ToString("N0")đ</span>
                                }
                            </div>
                            <div class="product-brand">
                                <small><i class="fas fa-building"></i> @(thuoc.ThuongHieu?.TenThuongHieu ?? "Đang cập nhật")</small>
                            </div>
                            <div class="mt-2">
                                <a asp-action="ChiTiet" asp-route-id="@thuoc.MaThuoc" class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-info-circle"></i> Chi tiết
                                </a>
                                @if (ngungKinhDoanh)
                                {
                                    <button type="button" class="btn btn-secondary btn-sm" disabled>
                                        <i class="fas fa-ban"></i> Ngừng bán
                                    </button>
                                }
                                else if (hetHang)
                                {
                                    <button type="button" class="btn btn-dark btn-sm" disabled>
                                        <i class="fas fa-times-circle"></i> Hết hàng
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-primary btn-sm" onclick="themVaoGioHang(@thuoc.MaThuoc, 1)">
                                        <i class="fas fa-cart-plus"></i> Thêm
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-tags fa-4x text-muted mb-3"></i>
            <h4>Chưa có sản phẩm khuyến mãi</h4>
            <p class="text-muted">Hãy quay lại sau để săn deal hot nhé!</p>
            <a asp-controller="Thuoc" asp-action="DanhSach" class="btn btn-primary">
                <i class="fas fa-shopping-bag me-1"></i> Xem tất cả sản phẩm
            </a>
        </div>
    }
</div>
