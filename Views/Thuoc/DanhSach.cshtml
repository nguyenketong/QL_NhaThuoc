@model IEnumerable<QL_NhaThuoc.Models.Thuoc>
@{
    ViewData["Title"] = "Danh sách thuốc";
}

<div class="container my-5">
    <h2 class="mb-4">
        <i class="fas fa-pills"></i> 
        @if (ViewBag.TenNhom != null)
        {
            <text>@ViewBag.TenNhom</text>
        }
        else if (ViewBag.TenThuongHieu != null)
        {
            <text>@ViewBag.TenThuongHieu</text>
        }
        else if (ViewBag.TuKhoa != null)
        {
            <text>Kết quả tìm kiếm: "@ViewBag.TuKhoa"</text>
        }
        else
        {
            <text>Danh sách thuốc</text>
        }
    </h2>

    <!-- Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="DanhSach">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Nhóm thuốc</label>
                        <select name="maNhom" class="form-select">
                            <option value="">Tất cả</option>
                            @if (ViewBag.DanhSachNhom != null)
                            {
                                foreach (var nhom in ViewBag.DanhSachNhom as IEnumerable<QL_NhaThuoc.Models.NhomThuoc>)
                                {
                                    <option value="@nhom.MaNhomThuoc">@nhom.TenNhomThuoc</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Thương hiệu</label>
                        <select name="maThuongHieu" class="form-select">
                            <option value="">Tất cả</option>
                            @if (ViewBag.DanhSachThuongHieu != null)
                            {
                                foreach (var th in ViewBag.DanhSachThuongHieu as IEnumerable<QL_NhaThuoc.Models.ThuongHieu>)
                                {
                                    <option value="@th.MaThuongHieu">@th.TenThuongHieu</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Giá từ</label>
                        <input type="number" name="giaMin" class="form-control" placeholder="0">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Giá đến</label>
                        <input type="number" name="giaMax" class="form-control" placeholder="1000000">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">&nbsp;</label>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-filter"></i> Lọc
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Products Grid -->
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var thuoc in Model)
            {
                var giaBan = thuoc.GiaBan ?? 0;
                var phanTramGiam = (thuoc.PhanTramGiam.HasValue && thuoc.PhanTramGiam.Value > 0) 
                    ? thuoc.PhanTramGiam.Value : 0;
                var giaGoc = thuoc.GiaGoc ?? (phanTramGiam > 0 ? Math.Ceiling(giaBan * 100 / (100 - phanTramGiam)) : giaBan);
                if (phanTramGiam == 0 && giaGoc > giaBan && giaGoc > 0)
                {
                    phanTramGiam = (int)((giaGoc - giaBan) * 100 / giaGoc);
                }
                var isHot = thuoc.IsHot ?? false;
                var isNew = thuoc.IsNew ?? false;
                
                <div class="col-md-3">
                    <div class="product-card position-relative">
                        @if (phanTramGiam > 0 || isHot || isNew)
                        {
                            <div class="product-badges position-absolute" style="top: 10px; left: 10px; z-index: 2;">
                                @if (phanTramGiam > 0)
                                {
                                    <span class="badge bg-danger">-@phanTramGiam%</span>
                                }
                                @if (isHot)
                                {
                                    <span class="badge bg-warning text-dark">HOT</span>
                                }
                                @if (isNew)
                                {
                                    <span class="badge bg-success">Mới</span>
                                }
                            </div>
                        }
                        <div class="product-image">
                            <img src="@(string.IsNullOrEmpty(thuoc.HinhAnh) ? "/images/no-image.svg" : thuoc.HinhAnh)" 
                                 alt="@thuoc.TenThuoc" onerror="this.src='/images/no-image.svg'" />
                        </div>
                        <div class="product-info">
                            <h6 class="product-name">@thuoc.TenThuoc</h6>
                            <div class="product-category">
                                <small class="text-muted">@(thuoc.NhomThuoc?.TenNhomThuoc ?? "")</small>
                            </div>
                            <div class="product-price">
                                <span class="price-new text-danger fw-bold">@giaBan.ToString("N0")đ</span>
                                @if (phanTramGiam > 0 && giaGoc > giaBan)
                                {
                                    <span class="price-old text-muted text-decoration-line-through ms-2">@giaGoc.ToString("N0")đ</span>
                                }
                            </div>
                            <div class="product-brand">
                                <small><i class="fas fa-building"></i> @(thuoc.ThuongHieu?.TenThuongHieu ?? "Đang cập nhật")</small>
                            </div>
                            <div class="mt-2">
                                <a asp-action="ChiTiet" asp-route-id="@thuoc.MaThuoc" 
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-info-circle"></i> Chi tiết
                                </a>
                                <button type="button" class="btn btn-primary btn-sm" onclick="themVaoGioHang(@thuoc.MaThuoc, 1)">
                                    <i class="fas fa-cart-plus"></i> Thêm
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle"></i> Không tìm thấy sản phẩm nào
                </div>
            </div>
        }
    </div>
</div>
